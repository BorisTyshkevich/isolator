#!/bin/bash
# Open URL in Chrome on the admin's GUI session.
# SSH sessions can't use `open` directly — no WindowServer connection.
# Use osascript via the admin user's launchd GUI domain instead.

URL="$1"
if [[ -z "$URL" ]]; then
    exit 0
fi

# Try direct open first (works if we have GUI access)
open -a "Google Chrome" "$URL" 2>/dev/null && exit 0

# Fallback: ask admin's GUI session to open it via launchd
ADMIN_UID=$(stat -f %u /Users/Shared 2>/dev/null || echo 501)
# Find admin username from the home that owns /Users/Shared parent
for u in /Users/*/; do
    uid=$(stat -f %u "$u" 2>/dev/null)
    if [[ "$uid" -ge 500 && "$uid" -le 510 ]]; then
        ADMIN_UID=$uid
        break
    fi
done

launchctl asuser "$ADMIN_UID" open -a "Google Chrome" "$URL" 2>/dev/null && exit 0

# Last resort: just print the URL
echo ""
echo "  Open this URL in your browser:"
echo "  $URL"
echo ""
