#!/usr/bin/env python3
"""apply-pf: Generate and load pf firewall rules from isolator config.

Usage:
    sudo apply-pf              # resolve hosts, generate anchor, load rules
    sudo apply-pf --dry-run    # print generated anchor without loading
"""

import os
import socket
import subprocess
import sys
import tomllib
from pathlib import Path

CONFIG_PATH = Path("/etc/isolator/config.toml")
ANCHOR_PATH = Path("/etc/pf.anchors/isolator")
PF_CONF = Path("/etc/pf.conf")


def load_config():
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def resolve_hosts(hosts):
    """Resolve hostnames to unique IPv4 addresses."""
    ips = set()
    for host in hosts:
        try:
            results = socket.getaddrinfo(host, 443, socket.AF_INET, socket.SOCK_STREAM)
            for _, _, _, _, addr in results:
                ips.add(addr[0])
        except socket.gaierror as e:
            print(f"  WARNING: cannot resolve {host}: {e}")
    return sorted(ips)


def generate_anchor(config):
    """Generate pf anchor content from config."""
    users = config.get("users", {})
    global_hosts = config.get("global", {}).get("hosts", [])

    lines = ["# Generated by isolator apply-pf", ""]

    all_uids = []

    # Per-user tables
    for name, user_config in users.items():
        uid = user_config["uid"]
        all_uids.append(uid)
        hosts = user_config.get("hosts", []) + global_hosts

        print(f"  Resolving hosts for {name} (uid={uid})...")
        for h in hosts:
            print(f"    {h}")
        ips = resolve_hosts(hosts)
        print(f"    -> {len(ips)} IPs")

        if ips:
            ip_list = ", ".join(ips)
            lines.append(f"table <{name}-allowed> {{ {ip_list} }}")

    lines.append("")

    if not all_uids:
        print("No users in config, nothing to do")
        return ""

    uid_list = " ".join(str(u) for u in all_uids)

    # Block all outbound for isolated users
    lines.append(f"block out proto tcp user {{ {uid_list} }}")
    lines.append(f"block out proto udp user {{ {uid_list} }}")
    lines.append("")

    # Per-user pass rules
    for name, user_config in users.items():
        uid = user_config["uid"]
        lines.append(f"pass out proto tcp user {uid} to <{name}-allowed> port 443")

    lines.append("")

    # DNS — local resolver only
    lines.append(f"pass out proto udp user {{ {uid_list} }} to 127.0.0.1 port 53")
    lines.append("")

    return "\n".join(lines)


def ensure_pf_conf():
    """Add isolator anchor to /etc/pf.conf if missing."""
    content = PF_CONF.read_text() if PF_CONF.exists() else ""
    if 'anchor "isolator"' not in content:
        print(f"  Adding anchor to {PF_CONF}")
        additions = '\nanchor "isolator"\nload anchor "isolator" from "/etc/pf.anchors/isolator"\n'
        PF_CONF.write_text(content + additions)


def main():
    if os.geteuid() != 0:
        print("Error: must run as root (sudo)")
        sys.exit(1)

    dry_run = "--dry-run" in sys.argv

    config = load_config()
    anchor = generate_anchor(config)

    if not anchor:
        return

    if dry_run:
        print("\n--- Generated anchor (dry run) ---")
        print(anchor)
        return

    print(f"\n  Writing {ANCHOR_PATH}")
    ANCHOR_PATH.parent.mkdir(parents=True, exist_ok=True)
    ANCHOR_PATH.write_text(anchor)

    ensure_pf_conf()

    print("  Loading pf rules...")
    r = subprocess.run(["pfctl", "-ef", str(PF_CONF)],
                       capture_output=True, text=True)
    if r.returncode != 0:
        print(f"  ERROR: pfctl failed: {r.stderr}")
        sys.exit(1)

    print("  pf rules loaded")


if __name__ == "__main__":
    main()
