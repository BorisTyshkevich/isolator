#!/usr/bin/env python3
"""create-user: Create an isolated macOS user for AI coding agents.

Usage:
    sudo create-user <name>                            # create, no auth
    sudo create-user <name> --from USER                # copy config from USER
    sudo create-user <name> --token TOKEN              # inject CLAUDE_CODE_OAUTH_TOKEN
    sudo create-user <name> --keychain-pass PASS       # copy admin keychain credentials
    sudo create-user --all --token TOKEN               # create all with token
    sudo create-user --all --keychain-pass PASS        # create all with keychain

Auth can also be set via env vars:
    CLAUDE_CODE_OAUTH_TOKEN=...  sudo create-user <name>
    ISOLATOR_KEYCHAIN_PASS=...   sudo create-user <name>
"""

import json
import os
import shutil
import subprocess
import sys
import tomllib
from pathlib import Path

CONFIG_PATH = Path("/etc/isolator/config.toml")
PROFILE_PATH = Path("/etc/isolator/profile")

SHELL_RC_FILES = {
    "bash": [".bash_profile", ".bashrc"],
    "zsh": [".zprofile", ".zshrc"],
}

# Login rc file per shell — where we append `source /etc/isolator/profile`
SHELL_LOGIN_RC = {
    "bash": ".bash_profile",
    "zsh": ".zprofile",
}

CLAUDE_SETTINGS_OVERRIDES = {
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": True,
}


CODEX_COPY_FILES = [
    "auth.json",
    "AGENTS.md",
]

CODEX_COPY_DIRS = [
    "plugins",
    "skills",
    "agents",
]

SHARED_TOOLS = [
    {
        "name": "codex",
        "bin": Path("/opt/homebrew/bin/codex"),
        "package_dir": Path("/opt/homebrew/lib/node_modules/@openai/codex"),
    },
]


def run(cmd, check=True):
    """Run a shell command."""
    r = subprocess.run(cmd, capture_output=True, text=True)
    if check and r.returncode != 0:
        print(f"  ERROR: {' '.join(cmd)}")
        if r.stderr:
            print(f"         {r.stderr.strip()}")
        r.check_returncode()
    return r


def run_as(user, cmd, check=True):
    """Run a command as another user. We're already root, so just switch uid/gid."""
    import pwd
    pw = pwd.getpwnam(user)
    home = pw.pw_dir

    def switch_user():
        os.setgid(pw.pw_gid)
        os.setuid(pw.pw_uid)
        os.environ["HOME"] = home

    r = subprocess.run(cmd, capture_output=True, text=True, preexec_fn=switch_user)
    if check and r.returncode != 0:
        print(f"  ERROR (as {user}): {' '.join(cmd)}")
        if r.stderr:
            print(f"         {r.stderr.strip()}")
        r.check_returncode()
    return r


def load_config():
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def dscl_read(user, key):
    """Read a dscl property, return value or None."""
    r = run(["dscl", ".", "-read", f"/Users/{user}", key], check=False)
    if r.returncode != 0:
        return None
    # dscl output: "Key: value" or multiline
    for line in r.stdout.strip().splitlines():
        if line.startswith(f"{key}:"):
            return line.split(":", 1)[1].strip()
    return None


def user_exists(name):
    r = run(["dscl", ".", "-read", f"/Users/{name}"], check=False)
    return r.returncode == 0


def detect_shell(user):
    """Detect user's shell, return 'bash' or 'zsh'."""
    shell = dscl_read(user, "UserShell") or "/bin/zsh"
    if "zsh" in shell:
        return "zsh", shell
    return "bash", shell


def create_macos_user(name, uid, shell_path):
    """Create a hidden macOS user via dscl."""
    home = f"/Users/{name}"
    print(f"  Creating macOS user {name} (uid={uid}, shell={shell_path})")

    run(["dscl", ".", "-create", f"/Users/{name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UserShell", shell_path])
    run(["dscl", ".", "-create", f"/Users/{name}", "RealName", f"Isolator {name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UniqueID", str(uid)])
    run(["dscl", ".", "-create", f"/Users/{name}", "PrimaryGroupID", "20"])
    run(["dscl", ".", "-create", f"/Users/{name}", "NFSHomeDirectory", home])
    run(["dscl", ".", "-create", f"/Users/{name}", "IsHidden", "1"])


def setup_home(name, admin):
    """Create home dir with proper permissions and ACL."""
    home = Path(f"/Users/{name}")
    print(f"  Setting up home {home}")

    home.mkdir(mode=0o700, exist_ok=True)
    run(["chown", f"{name}:staff", str(home)])
    run(["chmod", "700", str(home)])

    # ACL — admin can read everything, inheritable
    run(["chmod", "+a",
         f"{admin} allow read,list,search,readattr,readextattr,readsecurity,file_inherit,directory_inherit",
         str(home)])


def copy_shell_config(name, source_user, shell_type):
    """Copy shell rc files from source user, append isolator profile source."""
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")
    rc_files = SHELL_RC_FILES.get(shell_type, [])
    login_rc = SHELL_LOGIN_RC.get(shell_type, ".bash_profile")

    for rc in rc_files:
        src = source_home / rc
        dst = home / rc
        if src.exists():
            print(f"  Copying {src} -> {dst}")
            shutil.copy2(src, dst)
        else:
            # Create empty file so we can append to login rc
            if rc == login_rc:
                dst.touch()

    # Append isolator profile source to all rc files (login + interactive)
    source_line = f"\nsource {PROFILE_PATH}\n"
    for rc in rc_files:
        rc_path = home / rc
        if not rc_path.exists():
            rc_path.touch()
        content = rc_path.read_text()
        if str(PROFILE_PATH) not in content:
            print(f"  Appending isolator profile to {rc_path}")
            rc_path.write_text(content + source_line)


def copy_claude_config(name, source_user):
    """Copy Claude Code config from source user."""
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")

    # ~/.claude/settings.json — copy and merge overrides
    claude_dir = home / ".claude"
    claude_dir.mkdir(exist_ok=True)

    src_settings = source_home / ".claude" / "settings.json"
    dst_settings = claude_dir / "settings.json"

    settings = {}
    if src_settings.exists():
        print(f"  Copying {src_settings}")
        settings = json.loads(src_settings.read_text())

    settings.update(CLAUDE_SETTINGS_OVERRIDES)
    dst_settings.write_text(json.dumps(settings, indent=2) + "\n")


    # ~/.claude.json — extract only mcpServers from source
    src_claude_json = source_home / ".claude.json"
    dst_claude_json = home / ".claude.json"

    # Keys to copy from source .claude.json
    CLAUDE_JSON_KEYS = [
        "mcpServers",
        "oauthAccount",
        "hasCompletedOnboarding",
        "lastOnboardingVersion",
        "numStartups",
        "firstStartTime",
        "migrationVersion",
        "opusProMigrationComplete",
        "sonnet45MigrationComplete",
        "sonnet1m45MigrationComplete",
        "opus45MigrationComplete",
        "thinkingMigrationComplete",
    ]

    claude_json_data = {}
    if src_claude_json.exists():
        try:
            data = json.loads(src_claude_json.read_text())
            for key in CLAUDE_JSON_KEYS:
                if key in data:
                    claude_json_data[key] = data[key]
            if "mcpServers" in claude_json_data:
                print(f"  Copying MCP servers: {list(claude_json_data['mcpServers'].keys())}")
            if "oauthAccount" in claude_json_data:
                print(f"  Copying OAuth account: {claude_json_data['oauthAccount'].get('emailAddress', '?')}")
        except (json.JSONDecodeError, KeyError):
            pass

    dst_claude_json.write_text(json.dumps(claude_json_data, indent=2) + "\n")

    # ~/.claude/skills — copy symlink
    src_skills = source_home / ".claude" / "skills"
    dst_skills = claude_dir / "skills"
    if src_skills.is_symlink():
        target = os.readlink(src_skills)
        print(f"  Linking skills -> {target}")
        if dst_skills.exists() or dst_skills.is_symlink():
            dst_skills.unlink()
        os.symlink(target, dst_skills)

    # ~/.claude/plugins/ — copy dir
    src_plugins = source_home / ".claude" / "plugins"
    dst_plugins = claude_dir / "plugins"
    if src_plugins.is_dir():
        print(f"  Copying plugins/")
        if dst_plugins.exists():
            shutil.rmtree(dst_plugins)
        shutil.copytree(src_plugins, dst_plugins)


def copy_path(src, dst):
    """Copy file, directory, or symlink from src to dst."""
    if dst.exists() or dst.is_symlink():
        if dst.is_dir() and not dst.is_symlink():
            shutil.rmtree(dst)
        else:
            dst.unlink()

    if src.is_symlink():
        os.symlink(os.readlink(src), dst)
    elif src.is_dir():
        shutil.copytree(src, dst, symlinks=True)
    else:
        shutil.copy2(src, dst)


def sanitize_codex_config(src, dst):
    """Copy ~/.codex/config.toml but drop source-user project trust entries."""
    try:
        lines = src.read_text().splitlines()
    except OSError:
        return False

    sanitized = []
    skip_section = False
    removed_projects = 0

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("[projects.") and stripped.endswith("]"):
            skip_section = True
            removed_projects += 1
            continue
        if skip_section and stripped.startswith("[") and stripped.endswith("]"):
            skip_section = False
        if not skip_section:
            sanitized.append(line)

    dst.write_text("\n".join(sanitized).rstrip() + "\n")
    print(f"  Copying {src} -> {dst} (dropped {removed_projects} project trust entries)")
    return True


def ensure_shared_tool_access():
    """Make selected Homebrew-installed tools executable by slot users."""
    for tool in SHARED_TOOLS:
        bin_path = tool["bin"]
        package_dir = tool["package_dir"]

        if not bin_path.exists():
            continue

        if not package_dir.exists():
            print(f"  WARNING: {tool['name']} binary exists but package dir {package_dir} is missing")
            continue

        print(f"  Ensuring shared access to {tool['name']} in {package_dir}")
        run(["chmod", "-R", "a+rX", str(package_dir)])
        if bin_path.is_symlink():
            run(["chmod", "-h", "755", str(bin_path)], check=False)


def copy_codex_config(name, source_user):
    """Copy curated Codex config from source user."""
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")
    src_codex = source_home / ".codex"
    dst_codex = home / ".codex"

    if not src_codex.exists():
        print("  No ~/.codex found in source user, skipping Codex config")
        return

    dst_codex.mkdir(exist_ok=True)

    src_config = src_codex / "config.toml"
    if src_config.exists():
        sanitize_codex_config(src_config, dst_codex / "config.toml")

    for rel in CODEX_COPY_FILES:
        src = src_codex / rel
        dst = dst_codex / rel
        if src.exists() or src.is_symlink():
            print(f"  Copying {src} -> {dst}")
            copy_path(src, dst)

    for rel in CODEX_COPY_DIRS:
        src = src_codex / rel
        dst = dst_codex / rel
        if src.exists() or src.is_symlink():
            print(f"  Copying {src} -> {dst}")
            copy_path(src, dst)




KEYCHAIN_PASS_VAR = "ISOLATOR_KEYCHAIN_PASS"
KEYCHAIN_NAME = "login.keychain-db"


def inject_auth_env(name):
    """Mode 1: CLAUDE_CODE_OAUTH_TOKEN in admin env → copy to slot's .env."""
    token = os.environ.get("CLAUDE_CODE_OAUTH_TOKEN")
    if not token:
        return False

    home = Path(f"/Users/{name}")
    env_file = home / ".env"
    env_file.write_text(f'# Isolator auth\nexport CLAUDE_CODE_OAUTH_TOKEN="{token}"\n')
    print(f"  Injected CLAUDE_CODE_OAUTH_TOKEN into .env")
    return True


def inject_auth_keychain(name):
    """Mode 2: ISOLATOR_KEYCHAIN_PASS in admin env → copy keychain credentials."""
    kc_pass = os.environ.get(KEYCHAIN_PASS_VAR)
    if not kc_pass:
        return False

    home = Path(f"/Users/{name}")
    kc_dir = home / "Library" / "Keychains"
    kc_file = kc_dir / KEYCHAIN_NAME

    # Read credential from admin's keychain
    r = run(["security", "find-generic-password",
             "-s", "Claude Code-credentials", "-w"], check=False)
    if r.returncode != 0:
        print(f"  WARNING: no Claude Code credentials in admin keychain, skipping")
        return False

    cred_value = r.stdout.strip()

    # Create slot's keychain
    kc_dir.mkdir(parents=True, exist_ok=True)
    run(["chown", "-R", f"{name}:staff", str(home / "Library")])

    if kc_file.exists():
        run_as(name, ["security", "delete-keychain", str(kc_file)], check=False)

    run_as(name, ["security", "create-keychain", "-p", kc_pass, str(kc_file)])
    run_as(name, ["security", "default-keychain", "-s", str(kc_file)])
    run_as(name, ["security", "list-keychains", "-s", str(kc_file)])
    run_as(name, ["security", "set-keychain-settings", str(kc_file)])
    run_as(name, ["security", "unlock-keychain", "-p", kc_pass, str(kc_file)])

    # Add credential
    run_as(name, ["security", "add-generic-password",
         "-s", "Claude Code-credentials",
         "-a", "Claude Code",
         "-w", cred_value,
         "-T", "",
         str(kc_file)])

    # Write .credentials.json so Claude Code uses fresh token (not stale cache)
    claude_dir = home / ".claude"
    claude_dir.mkdir(exist_ok=True)
    creds_file = claude_dir / ".credentials.json"
    creds_file.write_text(cred_value + "\n")

    # Replace .env: remove stale token, store keychain password for profile unlock
    env_file = home / ".env"
    env_file.write_text(f'# Isolator auth (keychain)\nexport ISOLATOR_KEYCHAIN_PASS="{kc_pass}"\n')

    print(f"  Copied Claude Code credentials to {name}'s keychain")
    return True


def inject_auth(name, user_config):
    """Inject auth from environment. Tries env token first, then keychain."""
    if inject_auth_env(name):
        return
    if inject_auth_keychain(name):
        return

    # Fallback: config-based key files (if [users.*.auth] exists)
    home = Path(f"/Users/{name}")
    auth = user_config.get("auth", {})
    if not auth:
        print(f"  No auth: set CLAUDE_CODE_OAUTH_TOKEN or {KEYCHAIN_PASS_VAR} in your env")
        return

    env_file = home / ".env"
    lines = ["# Isolator auth"]
    for var, keyfile in auth.items():
        keypath = Path(keyfile)
        if not keypath.exists():
            print(f"  WARNING: key file {keypath} not found, skipping {var}")
            continue
        value = keypath.read_text().strip()
        lines.append(f'export {var}="{value}"')
        print(f"  Injecting {var} from {keypath}")

    env_file.write_text("\n".join(lines) + "\n")


def create_skeleton(name):
    """Create standard directory skeleton."""
    home = Path(f"/Users/{name}")
    for d in [".local/bin", ".local/lib", ".npm-global", ".cache", "workspace"]:
        (home / d).mkdir(parents=True, exist_ok=True)


def set_ownership(name):
    """Set final ownership: config files root-owned 444, home dirs owned by user."""
    home = Path(f"/Users/{name}")

    # Config files — root-owned, read-only
    for f in [".bash_profile", ".bashrc", ".zprofile", ".zshrc",
              ".env", ".claude/settings.json",
              ".claude.json", ".codex/config.toml", ".codex/AGENTS.md"]:
        path = home / f
        if path.exists():
            run(["chown", "root:wheel", str(path)])
            run(["chmod", "444", str(path)])

    # .claude dir — slot-owned (Claude needs to create subdirs for sessions, etc.)
    claude_dir = home / ".claude"
    if claude_dir.exists():
        run(["chown", f"{name}:staff", str(claude_dir)])
        run(["chmod", "700", str(claude_dir)])

    # plugins — root-owned
    plugins_dir = home / ".claude" / "plugins"
    if plugins_dir.exists():
        run(["chown", "-R", "root:wheel", str(plugins_dir)])
        run(["chmod", "-R", "755", str(plugins_dir)])

    # .claude.json — slot-owned (Claude writes state to it)
    cj = home / ".claude.json"
    if cj.exists():
        run(["chown", f"{name}:staff", str(cj)])
        run(["chmod", "600", str(cj)])

    # .codex dir — slot-owned for runtime state
    codex_dir = home / ".codex"
    if codex_dir.exists():
        run(["chown", f"{name}:staff", str(codex_dir)])
        run(["chmod", "700", str(codex_dir)])

    # auth.json — slot-owned (Codex may refresh tokens)
    codex_auth = codex_dir / "auth.json"
    if codex_auth.exists():
        run(["chown", f"{name}:staff", str(codex_auth)])
        run(["chmod", "600", str(codex_auth)])

    # Curated Codex content — root-owned, read-only
    for rel in [".codex/plugins", ".codex/skills", ".codex/agents"]:
        path = home / rel
        if path.exists():
            if path.is_symlink():
                run(["chown", "-h", "root:wheel", str(path)])
            else:
                run(["chown", "-R", "root:wheel", str(path)])
                run(["chmod", "-R", "755", str(path)])

    # Everything else — owned by slot user
    for d in [".local", ".npm-global", ".cache", "workspace"]:
        path = home / d
        if path.exists():
            run(["chown", "-R", f"{name}:staff", str(path)])


def create_user(name, config, from_user=None):
    """Create one isolated user."""
    users = config.get("users", {})
    admin = config["admin"]

    if name not in users:
        print(f"Error: {name} not found in config")
        sys.exit(1)

    user_config = users[name]
    uid = user_config["uid"]

    # Resolve source user: --from > config from > admin
    source = from_user or user_config.get("from", admin)

    print(f"\n=== Creating {name} (uid={uid}, from={source}) ===")

    # Ensure admin home is not world-readable
    admin_home = Path(f"/Users/{admin}")
    if admin_home.stat().st_mode & 0o077:
        print(f"  Locking admin home {admin_home} to 700")
        run(["chmod", "700", str(admin_home)])

    if user_exists(name):
        print(f"  User {name} already exists, skipping dscl creation")
    else:
        shell_type, shell_path = detect_shell(source)
        create_macos_user(name, uid, shell_path)

    shell_type, shell_path = detect_shell(source)

    setup_home(name, admin)
    copy_shell_config(name, source, shell_type)
    copy_claude_config(name, source)
    copy_codex_config(name, source)
    inject_auth(name, user_config)
    create_skeleton(name)
    ensure_shared_tool_access()
    set_ownership(name)

    print(f"=== Done: {name} ===")


def main():
    if os.geteuid() != 0:
        print("Error: must run as root (sudo)")
        sys.exit(1)

    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    config = load_config()

    # Parse --token and --keychain-pass into env vars
    # so the auth functions can read them uniformly
    args = sys.argv[1:]
    if "--token" in args:
        idx = args.index("--token")
        if idx + 1 < len(args):
            os.environ["CLAUDE_CODE_OAUTH_TOKEN"] = args.pop(idx + 1)
            args.pop(idx)
        else:
            print("Error: --token requires a value")
            sys.exit(1)

    if "--keychain-pass" in args:
        idx = args.index("--keychain-pass")
        if idx + 1 < len(args):
            os.environ["ISOLATOR_KEYCHAIN_PASS"] = args.pop(idx + 1)
            args.pop(idx)
        else:
            print("Error: --keychain-pass requires a value")
            sys.exit(1)

    from_user = None
    if "--from" in args:
        idx = args.index("--from")
        if idx + 1 < len(args):
            from_user = args.pop(idx + 1)
            args.pop(idx)
        else:
            print("Error: --from requires a username")
            sys.exit(1)

    if not args:
        print(__doc__)
        sys.exit(1)

    if args[0] == "--all":
        for name in config.get("users", {}):
            create_user(name, config, from_user)
    else:
        create_user(args[0], config, from_user)


if __name__ == "__main__":
    main()
