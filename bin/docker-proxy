#!/usr/bin/env python3
"""docker-proxy: Per-user Docker socket proxy that restricts volume mounts.

Inspects every HTTP request on keep-alive connections.
Only inspects container create — all other requests pass through.
After the first streaming endpoint (attach/wait/exec), switches to raw relay.
"""

import argparse
import json
import os
import signal
import socket
import sys
import threading
from pathlib import Path

WORKSPACES_DIR = "/Users/Workspaces"


def log(user, msg):
    print(f"[{user}] {msg}", flush=True)


def resolve_path(path):
    try:
        return str(Path(path).resolve())
    except (OSError, ValueError):
        return path


def is_path_allowed(path, user):
    """Allow only the user's own workspace. /tmp is shared and dangerous."""
    resolved = resolve_path(path)
    user_ws = f"{WORKSPACES_DIR}/{user}"
    if resolved == user_ws or resolved.startswith(user_ws + "/"):
        return True
    return False


# HostConfig fields we explicitly allow (everything else gets default).
# Anything dangerous must be explicitly handled in check_create.
SAFE_HOST_CONFIG_FIELDS = {
    "Binds", "Mounts", "NetworkMode", "PortBindings", "RestartPolicy",
    "AutoRemove", "ContainerIDFile", "LogConfig", "VolumeDriver",
    "ConsoleSize", "DnsOptions", "DnsSearch", "ExtraHosts", "GroupAdd",
    "Memory", "MemorySwap", "MemorySwappiness", "MemoryReservation",
    "CpuShares", "CpuPercent", "CpuQuota", "CpuPeriod", "CpusetCpus", "CpusetMems",
    "NanoCpus", "BlkioWeight", "PidsLimit", "Isolation",
    "ShmSize", "Tmpfs", "ReadonlyRootfs", "ReadonlyPaths", "MaskedPaths",
    "PublishAllPorts", "Links",  # Links is deprecated but harmless
}

# Dangerous HostConfig fields that must be explicitly checked/rejected
DANGEROUS_HOST_CONFIG = {
    "Privileged", "VolumesFrom", "Devices", "DeviceCgroupRules", "DeviceRequests",
    "CapAdd", "CapDrop", "SecurityOpt", "PidMode", "IpcMode", "UTSMode",
    "UsernsMode", "CgroupnsMode", "CgroupParent", "Cgroup", "Runtime",
    "Sysctls", "Ulimits", "OomScoreAdj", "OomKillDisable",
}


def check_create(body_bytes, user):
    try:
        data = json.loads(body_bytes)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return False, "invalid JSON body"

    hc = data.get("HostConfig") or {}

    # Reject any dangerous field that's set (truthy)
    for field in DANGEROUS_HOST_CONFIG:
        val = hc.get(field)
        if val:  # non-empty list, dict, true, non-empty string
            return False, f"{field} is not allowed"

    # Network: must be empty (default), bridge, or iso-<user>
    nm = hc.get("NetworkMode", "")
    allowed_networks = {"", "default", "bridge", f"iso-{user}"}
    if nm not in allowed_networks:
        return False, f"NetworkMode {nm!r} not allowed (must be: bridge or iso-{user})"

    # Bind mounts
    for bind in hc.get("Binds") or []:
        source = bind.split(":")[0]
        if not source.startswith("/"):
            continue  # named volume
        if not is_path_allowed(source, user):
            return False, f"bind mount not allowed: {source}"
        if "docker.sock" in resolve_path(source):
            return False, "mounting Docker socket is not allowed"

    # Mount API
    for mount in hc.get("Mounts") or []:
        if mount.get("Type") == "bind":
            source = mount.get("Source", "")
            if not is_path_allowed(source, user):
                return False, f"mount not allowed: {source}"
            if "docker.sock" in resolve_path(source):
                return False, "mounting Docker socket is not allowed"

    # Container User: reject empty/root/0
    container_user = data.get("User", "").strip()
    if container_user in ("", "root", "0", "0:0"):
        # Allow images that set USER explicitly via Dockerfile,
        # but reject explicit root requests at container create time
        if container_user in ("root", "0", "0:0"):
            return False, f"container user {container_user!r} not allowed"

    return True, ""


def relay(src, dst):
    try:
        while True:
            data = src.recv(65536)
            if not data:
                break
            dst.sendall(data)
    except (BrokenPipeError, ConnectionResetError, OSError):
        pass
    try:
        dst.shutdown(socket.SHUT_WR)
    except OSError:
        pass


def handle(client, upstream_path, user):
    upstream = None
    try:
        upstream = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        upstream.connect(upstream_path)

        leftover = b""
        while True:
            # Read next HTTP request headers
            buf = leftover
            leftover = b""
            while b"\r\n\r\n" not in buf:
                chunk = client.recv(8192)
                if not chunk:
                    return
                buf += chunk

            hdr_end = buf.index(b"\r\n\r\n") + 4
            hdr = buf[:hdr_end].decode("utf-8", errors="replace")
            after_hdr = buf[hdr_end:]

            parts = hdr.split("\r\n")[0].split(" ", 2)
            method = parts[0] if parts else ""
            path = parts[1] if len(parts) > 1 else ""

            # Reject smuggling vectors: Transfer-Encoding and duplicate Content-Length
            cl_count = 0
            content_length = 0
            for line in hdr.split("\r\n"):
                low = line.lower()
                if low.startswith("transfer-encoding:"):
                    err = json.dumps({"message": "isolator: Transfer-Encoding not allowed"})
                    resp = (
                        f"HTTP/1.1 400 Bad Request\r\n"
                        f"Content-Type: application/json\r\n"
                        f"Content-Length: {len(err)}\r\n"
                        f"Connection: close\r\n\r\n{err}"
                    ).encode()
                    client.sendall(resp)
                    log(user, "BLOCKED: Transfer-Encoding (smuggling)")
                    return
                if low.startswith("content-length:"):
                    cl_count += 1
                    content_length = int(line.split(":", 1)[1].strip())
            if cl_count > 1:
                err = json.dumps({"message": "isolator: duplicate Content-Length"})
                resp = (
                    f"HTTP/1.1 400 Bad Request\r\n"
                    f"Content-Type: application/json\r\n"
                    f"Content-Length: {len(err)}\r\n"
                    f"Connection: close\r\n\r\n{err}"
                ).encode()
                client.sendall(resp)
                log(user, "BLOCKED: duplicate Content-Length (smuggling)")
                return

            # Read body
            body = after_hdr[:content_length]
            leftover = after_hdr[content_length:]
            while len(body) < content_length:
                chunk = client.recv(65536)
                if not chunk:
                    return
                needed = content_length - len(body)
                body += chunk[:needed]
                if len(chunk) > needed:
                    leftover += chunk[needed:]

            # Inspect container create
            if method == "POST" and "/containers/create" in path:
                ok, reason = check_create(body, user)
                if not ok:
                    err = json.dumps({"message": f"isolator: {reason}"})
                    resp = (
                        f"HTTP/1.1 403 Forbidden\r\n"
                        f"Content-Type: application/json\r\n"
                        f"Content-Length: {len(err)}\r\n"
                        f"Connection: close\r\n"
                        f"\r\n{err}"
                    ).encode()
                    client.sendall(resp)
                    log(user, f"BLOCKED: {reason}")
                    return

            # Forward request to upstream
            upstream.sendall(buf[:hdr_end] + body)

            # For streaming endpoints: switch to raw bidirectional relay
            # and stop parsing HTTP — these don't return until done
            if any(s in path for s in ["/attach", "/exec", "/wait", "/logs"]):
                if leftover:
                    upstream.sendall(leftover)
                t = threading.Thread(target=relay, args=(upstream, client), daemon=True)
                t.start()
                relay(client, upstream)
                t.join(timeout=5)
                return

            # For normal request/response: read response and forward
            # Use raw relay for the response to avoid parsing issues
            # But we need to know when the response ends to continue the loop
            # Read response headers
            resp_buf = b""
            while b"\r\n\r\n" not in resp_buf:
                chunk = upstream.recv(8192)
                if not chunk:
                    return
                resp_buf += chunk

            resp_hdr_end = resp_buf.index(b"\r\n\r\n") + 4
            resp_hdr = resp_buf[:resp_hdr_end].decode("utf-8", errors="replace")
            resp_after = resp_buf[resp_hdr_end:]

            resp_cl = 0
            chunked = False
            for line in resp_hdr.split("\r\n"):
                low = line.lower()
                if low.startswith("content-length:"):
                    resp_cl = int(line.split(":", 1)[1].strip())
                if low.startswith("transfer-encoding:") and "chunked" in low:
                    chunked = True

            if chunked:
                body_buf = resp_after
                while not body_buf.endswith(b"0\r\n\r\n"):
                    chunk = upstream.recv(65536)
                    if not chunk:
                        break
                    body_buf += chunk
                client.sendall(resp_buf[:resp_hdr_end] + body_buf)
            elif resp_cl > 0:
                body_buf = resp_after
                while len(body_buf) < resp_cl:
                    chunk = upstream.recv(65536)
                    if not chunk:
                        break
                    body_buf += chunk
                leftover = body_buf[resp_cl:]
                client.sendall(resp_buf[:resp_hdr_end] + body_buf[:resp_cl])
            else:
                client.sendall(resp_buf)

    except Exception as e:
        log(user, f"ERROR: {e}")
    finally:
        client.close()
        if upstream:
            upstream.close()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--user", required=True)
    parser.add_argument("--socket", required=True)
    parser.add_argument("--upstream", default="/var/run/docker.sock")
    args = parser.parse_args()

    if os.path.exists(args.socket):
        os.unlink(args.socket)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(args.socket)
    os.chmod(args.socket, 0o777)
    server.listen(32)

    log(args.user, f"proxy: {args.socket} → {args.upstream}")

    def shutdown(sig, frame):
        server.close()
        try:
            os.unlink(args.socket)
        except OSError:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    while True:
        try:
            client, _ = server.accept()
            t = threading.Thread(target=handle,
                                 args=(client, args.upstream, args.user),
                                 daemon=True)
            t.start()
        except OSError:
            break


if __name__ == "__main__":
    main()
