#!/usr/bin/env python3
"""docker-proxy: Per-user Docker socket proxy that restricts volume mounts.

Inspects every HTTP request on keep-alive connections.
Only inspects container create — all other requests pass through.
After the first streaming endpoint (attach/wait/exec), switches to raw relay.
"""

import argparse
import json
import os
import signal
import socket
import sys
import threading
from pathlib import Path

WORKSPACES_DIR = "/Users/Workspaces"
MAX_BODY_SIZE = 16 * 1024 * 1024  # 16 MB — generous for create JSON, blocks OOM


def log(user, msg):
    print(f"[{user}] {msg}", flush=True)


def resolve_path(path):
    try:
        return str(Path(path).resolve())
    except (OSError, ValueError):
        return path


def is_path_allowed(path, user):
    """Allow only the user's own workspace and ~/tmp.

    /tmp and /private/tmp are shared between sandbox users → blocked.
    Per-user TMPDIR is /Users/<user>/tmp/ (set by profile).
    """
    resolved = resolve_path(path)
    user_ws = f"{WORKSPACES_DIR}/{user}"
    user_tmp = f"/Users/{user}/tmp"
    if resolved == user_ws or resolved.startswith(user_ws + "/"):
        return True
    if resolved == user_tmp or resolved.startswith(user_tmp + "/"):
        return True
    return False


# HostConfig fields we explicitly allow (everything else gets default).
# Anything dangerous must be explicitly handled in check_create.
SAFE_HOST_CONFIG_FIELDS = {
    "Binds", "Mounts", "NetworkMode", "PortBindings", "RestartPolicy",
    "AutoRemove", "ContainerIDFile", "LogConfig", "VolumeDriver",
    "ConsoleSize", "DnsOptions", "DnsSearch", "ExtraHosts", "GroupAdd",
    "Memory", "MemorySwap", "MemorySwappiness", "MemoryReservation",
    "CpuShares", "CpuPercent", "CpuQuota", "CpuPeriod", "CpusetCpus", "CpusetMems",
    "NanoCpus", "BlkioWeight", "PidsLimit", "Isolation",
    "ShmSize", "Tmpfs", "ReadonlyRootfs", "ReadonlyPaths", "MaskedPaths",
    "PublishAllPorts", "Links",  # Links is deprecated but harmless
}

# Dangerous HostConfig fields that must be explicitly checked/rejected
DANGEROUS_HOST_CONFIG = {
    "Privileged", "VolumesFrom", "Devices", "DeviceCgroupRules", "DeviceRequests",
    "CapAdd", "CapDrop", "SecurityOpt", "PidMode", "IpcMode", "UTSMode",
    "UsernsMode", "CgroupnsMode", "CgroupParent", "Cgroup", "Runtime",
    "Sysctls", "Ulimits", "OomScoreAdj", "OomKillDisable",
    "ExtraHosts", "DNS", "DNSOptions", "DNSSearch",  # DNS/host spoofing
    "Links",  # legacy, redundant — disallow
}

# Default-deny endpoint allowlist. Anything not matching one of these
# regex patterns is rejected. Matches against just the path (no query).
import re
_GENERIC_ENDPOINT_ALLOW = [
    re.compile(p) for p in [
        r"^/v[\d.]+/_ping$",
        r"^/_ping$",
        r"^/v[\d.]+/version$",
        r"^/v[\d.]+/info$",
        r"^/v[\d.]+/containers/json$",  # list
        r"^/v[\d.]+/containers/create$",  # validated separately
        r"^/v[\d.]+/containers/[a-zA-Z0-9_.-]+/(start|stop|restart|kill|pause|unpause|wait|attach|logs|inspect|stats|top|changes|export|exec|json)(/.*)?$",
        r"^/v[\d.]+/containers/[a-zA-Z0-9_.-]+/archive$",
        r"^/v[\d.]+/containers/[a-zA-Z0-9_.-]+$",  # delete
        r"^/v[\d.]+/exec/[a-zA-Z0-9_.-]+/(start|resize|json)$",
        r"^/v[\d.]+/images/.*$",  # pull, list, inspect, delete
        r"^/v[\d.]+/build$",  # docker build (uploads context tar)
        r"^/v[\d.]+/networks/json$",
        r"^/v[\d.]+/networks/bridge(/.*)?$",
        r"^/v[\d.]+/volumes/.*$",  # named volumes (no host paths)
        r"^/v[\d.]+/system/df$",
        r"^/v[\d.]+/system/events$",
    ]
]


def is_endpoint_allowed(method, path, user="acm"):
    """Default-deny: only specific endpoints pass.

    Network endpoints restricted to iso-<user> only — other users' networks
    and arbitrary network names are rejected.
    """
    plain = path.split("?", 1)[0]
    if any(p.match(plain) for p in _GENERIC_ENDPOINT_ALLOW):
        return True
    # User-specific iso network endpoint: /vX/networks/iso-<user> or .../iso-<user>/sub
    iso_net_re = re.compile(rf"^/v[\d.]+/networks/iso-{re.escape(user)}(/.*)?$")
    if iso_net_re.match(plain):
        return True
    return False


def check_create(body_bytes, user):
    """Validate and rewrite a container create request.

    Returns (ok, reason, new_body_bytes). The new body has all bind mount
    paths replaced with their realpath() result — Docker will then mount
    exactly what we validated, not what a symlink points to at mount time.
    """
    try:
        data = json.loads(body_bytes)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return False, "invalid JSON body", body_bytes

    hc = data.get("HostConfig") or {}

    # Reject any dangerous field that's set (truthy)
    for field in DANGEROUS_HOST_CONFIG:
        val = hc.get(field)
        if val:
            return False, f"{field} is not allowed", body_bytes

    # NetworkMode: only iso-<user> network (bridge has no egress filtering).
    # Empty/default/bridge are allowed but will be dropped by iptables — the
    # agent will see "no route" for any egress, which is a feature.
    nm = hc.get("NetworkMode", "")
    allowed_networks = {"", "default", "bridge", f"iso-{user}"}
    if nm not in allowed_networks:
        return False, f"NetworkMode {nm!r} not allowed (use iso-{user})", body_bytes

    # NetworkingConfig.EndpointsConfig — additional networks to attach.
    # Only iso-<user> is allowed (prevents joining other users' networks).
    nc = data.get("NetworkingConfig") or {}
    for ep_name in (nc.get("EndpointsConfig") or {}).keys():
        if ep_name not in allowed_networks:
            return False, f"network {ep_name!r} not allowed (use iso-{user})", body_bytes

    # Validate AND rewrite Binds to use resolved paths (TOCTOU-safe)
    new_binds = []
    for bind in hc.get("Binds") or []:
        parts = bind.split(":")
        source = parts[0]
        if not source.startswith("/"):
            new_binds.append(bind)  # named volume — pass through
            continue
        resolved = resolve_path(source)
        if not is_path_allowed(resolved, user):
            return False, f"bind mount not allowed: {source}", body_bytes
        if "docker.sock" in resolved:
            return False, "mounting Docker socket is not allowed", body_bytes
        # Replace source with resolved path
        parts[0] = resolved
        new_binds.append(":".join(parts))
    if hc.get("Binds"):
        hc["Binds"] = new_binds

    # Validate AND rewrite Mounts (Type=bind)
    new_mounts = []
    for mount in hc.get("Mounts") or []:
        mtype = mount.get("Type")
        if mtype == "bind":
            source = mount.get("Source", "")
            resolved = resolve_path(source)
            if not is_path_allowed(resolved, user):
                return False, f"mount not allowed: {source}", body_bytes
            if "docker.sock" in resolved:
                return False, "mounting Docker socket is not allowed", body_bytes
            mount = dict(mount)
            mount["Source"] = resolved
        elif mtype == "volume":
            # Volume with DriverConfig.Options.device = bind mount in disguise
            vo = (mount.get("VolumeOptions") or {}).get("DriverConfig") or {}
            if (vo.get("Options") or {}).get("device"):
                return False, "volume DriverConfig.device not allowed (bind mount via volume)", body_bytes
        elif mtype == "tmpfs":
            pass  # tmpfs is fine
        else:
            return False, f"mount type {mtype!r} not allowed", body_bytes
        new_mounts.append(mount)
    if hc.get("Mounts"):
        hc["Mounts"] = new_mounts

    # Container User: reject explicit root
    container_user = (data.get("User", "") or "").strip()
    if container_user in ("root", "0", "0:0"):
        return False, f"container user {container_user!r} not allowed", body_bytes

    # Re-serialize the (possibly modified) body
    return True, "", json.dumps(data).encode()


def relay(src, dst):
    try:
        while True:
            data = src.recv(65536)
            if not data:
                break
            dst.sendall(data)
    except (BrokenPipeError, ConnectionResetError, OSError):
        pass
    try:
        dst.shutdown(socket.SHUT_WR)
    except OSError:
        pass


def get_peer_uid(sock):
    """Get UID of the connecting peer (macOS/BSD)."""
    import struct
    try:
        # macOS: LOCAL_PEERCRED returns struct xucred
        # First 4 bytes = version, next 4 = uid
        SOL_LOCAL = 0
        LOCAL_PEERCRED = 0x001
        # xucred: cr_version (uint32), cr_uid (uid_t=uint32), ngroups, groups[16]
        data = sock.getsockopt(SOL_LOCAL, LOCAL_PEERCRED, 76)
        version, uid = struct.unpack_from("II", data)
        return uid
    except OSError:
        return None


def handle(client, upstream_path, user, expected_uid, check_peer=True):
    upstream = None
    try:
        # Defense-in-depth: verify peer UID matches expected user
        if check_peer:
            peer_uid = get_peer_uid(client)
            if peer_uid is not None and peer_uid != expected_uid:
                log(user, f"BLOCKED: peer uid={peer_uid} does not match expected uid={expected_uid}")
                client.close()
                return

        upstream = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        upstream.connect(upstream_path)

        leftover = b""
        while True:
            # Read next HTTP request headers
            buf = leftover
            leftover = b""
            while b"\r\n\r\n" not in buf:
                chunk = client.recv(8192)
                if not chunk:
                    return
                buf += chunk

            hdr_end = buf.index(b"\r\n\r\n") + 4
            hdr = buf[:hdr_end].decode("utf-8", errors="replace")
            after_hdr = buf[hdr_end:]

            parts = hdr.split("\r\n")[0].split(" ", 2)
            method = parts[0] if parts else ""
            path = parts[1] if len(parts) > 1 else ""

            # Endpoint allowlist (default-deny)
            if not is_endpoint_allowed(method, path, user):
                err = json.dumps({"message": f"isolator: endpoint not allowed: {method} {path}"})
                resp = (
                    f"HTTP/1.1 403 Forbidden\r\n"
                    f"Content-Type: application/json\r\n"
                    f"Content-Length: {len(err)}\r\n"
                    f"Connection: close\r\n\r\n{err}"
                ).encode()
                client.sendall(resp)
                log(user, f"BLOCKED endpoint: {method} {path}")
                return

            # Reject smuggling vectors: Transfer-Encoding and duplicate Content-Length
            cl_count = 0
            content_length = 0
            for line in hdr.split("\r\n"):
                low = line.lower()
                if low.startswith("transfer-encoding:"):
                    err = json.dumps({"message": "isolator: Transfer-Encoding not allowed"})
                    resp = (
                        f"HTTP/1.1 400 Bad Request\r\n"
                        f"Content-Type: application/json\r\n"
                        f"Content-Length: {len(err)}\r\n"
                        f"Connection: close\r\n\r\n{err}"
                    ).encode()
                    client.sendall(resp)
                    log(user, "BLOCKED: Transfer-Encoding (smuggling)")
                    return
                if low.startswith("content-length:"):
                    cl_count += 1
                    content_length = int(line.split(":", 1)[1].strip())
            if cl_count > 1:
                err = json.dumps({"message": "isolator: duplicate Content-Length"})
                resp = (
                    f"HTTP/1.1 400 Bad Request\r\n"
                    f"Content-Type: application/json\r\n"
                    f"Content-Length: {len(err)}\r\n"
                    f"Connection: close\r\n\r\n{err}"
                ).encode()
                client.sendall(resp)
                log(user, "BLOCKED: duplicate Content-Length (smuggling)")
                return

            # Reject oversize bodies — we buffer in memory, OOM defense.
            # /build can stream large context tars, so allow it via raw passthrough later.
            if content_length > MAX_BODY_SIZE and "/build" not in path:
                err = json.dumps({"message": f"isolator: request body too large ({content_length} bytes)"})
                resp = (
                    f"HTTP/1.1 413 Payload Too Large\r\n"
                    f"Content-Type: application/json\r\n"
                    f"Content-Length: {len(err)}\r\n"
                    f"Connection: close\r\n\r\n{err}"
                ).encode()
                client.sendall(resp)
                log(user, f"BLOCKED: oversize body {content_length}")
                return

            # Read body
            body = after_hdr[:content_length]
            leftover = after_hdr[content_length:]
            while len(body) < content_length:
                chunk = client.recv(65536)
                if not chunk:
                    return
                needed = content_length - len(body)
                body += chunk[:needed]
                if len(chunk) > needed:
                    leftover += chunk[needed:]

            # Inspect container create — and rewrite paths to prevent TOCTOU
            if method == "POST" and "/containers/create" in path:
                ok, reason, new_body = check_create(body, user)
                if not ok:
                    err = json.dumps({"message": f"isolator: {reason}"})
                    resp = (
                        f"HTTP/1.1 403 Forbidden\r\n"
                        f"Content-Type: application/json\r\n"
                        f"Content-Length: {len(err)}\r\n"
                        f"Connection: close\r\n"
                        f"\r\n{err}"
                    ).encode()
                    client.sendall(resp)
                    log(user, f"BLOCKED: {reason}")
                    return
                # Replace body with rewritten version (resolved paths)
                if new_body != body:
                    # Rebuild header with updated Content-Length
                    new_hdr_lines = []
                    for line in hdr.split("\r\n"):
                        if line.lower().startswith("content-length:"):
                            new_hdr_lines.append(f"Content-Length: {len(new_body)}")
                        else:
                            new_hdr_lines.append(line)
                    new_hdr = "\r\n".join(new_hdr_lines)
                    upstream.sendall(new_hdr.encode() + new_body)
                else:
                    upstream.sendall(buf[:hdr_end] + body)
            else:
                # Forward request to upstream as-is
                upstream.sendall(buf[:hdr_end] + body)

            # For streaming endpoints: switch to raw bidirectional relay
            # and stop parsing HTTP — these don't return until done
            if any(s in path for s in ["/attach", "/exec", "/wait", "/logs"]):
                if leftover:
                    upstream.sendall(leftover)
                t = threading.Thread(target=relay, args=(upstream, client), daemon=True)
                t.start()
                relay(client, upstream)
                t.join(timeout=5)
                return

            # For normal request/response: read response and forward
            # Use raw relay for the response to avoid parsing issues
            # But we need to know when the response ends to continue the loop
            # Read response headers
            resp_buf = b""
            while b"\r\n\r\n" not in resp_buf:
                chunk = upstream.recv(8192)
                if not chunk:
                    return
                resp_buf += chunk

            resp_hdr_end = resp_buf.index(b"\r\n\r\n") + 4
            resp_hdr = resp_buf[:resp_hdr_end].decode("utf-8", errors="replace")
            resp_after = resp_buf[resp_hdr_end:]

            resp_cl = 0
            chunked = False
            for line in resp_hdr.split("\r\n"):
                low = line.lower()
                if low.startswith("content-length:"):
                    resp_cl = int(line.split(":", 1)[1].strip())
                if low.startswith("transfer-encoding:") and "chunked" in low:
                    chunked = True

            if chunked:
                body_buf = resp_after
                while not body_buf.endswith(b"0\r\n\r\n"):
                    chunk = upstream.recv(65536)
                    if not chunk:
                        break
                    body_buf += chunk
                client.sendall(resp_buf[:resp_hdr_end] + body_buf)
            elif resp_cl > 0:
                body_buf = resp_after
                while len(body_buf) < resp_cl:
                    chunk = upstream.recv(65536)
                    if not chunk:
                        break
                    body_buf += chunk
                leftover = body_buf[resp_cl:]
                client.sendall(resp_buf[:resp_hdr_end] + body_buf[:resp_cl])
            else:
                client.sendall(resp_buf)

    except Exception as e:
        log(user, f"ERROR: {e}")
    finally:
        client.close()
        if upstream:
            upstream.close()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--user", required=True)
    parser.add_argument("--socket", required=True)
    parser.add_argument("--upstream", default="/var/run/docker.sock")
    parser.add_argument("--insecure-skip-checks", action="store_true",
                        help="Skip ownership/UID checks (testing only)")
    args = parser.parse_args()

    # Verify parent dir is root-owned (defense against squatting)
    parent = Path(args.socket).parent
    st = parent.stat()
    if not args.insecure_skip_checks and st.st_uid != 0:
        print(f"FATAL: {parent} is not root-owned (uid={st.st_uid}) — refusing to start")
        sys.exit(1)

    if os.path.exists(args.socket):
        os.unlink(args.socket)

    # Resolve target user UID for socket ownership and SO_PEERCRED check
    import pwd
    try:
        target_uid = pwd.getpwnam(args.user).pw_uid
    except KeyError:
        if args.insecure_skip_checks:
            target_uid = os.getuid()
        else:
            print(f"FATAL: user {args.user!r} not found")
            sys.exit(1)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    # Set umask before bind so socket is created with restrictive perms
    old_umask = os.umask(0o077)
    try:
        server.bind(args.socket)
    finally:
        os.umask(old_umask)
    # Socket must be owned by target user with mode 600 — only that user can connect
    if not args.insecure_skip_checks:
        os.chown(args.socket, target_uid, -1)
    os.chmod(args.socket, 0o600)
    server.listen(32)

    log(args.user, f"proxy: {args.socket} (uid={target_uid}, mode 600) → {args.upstream}")

    def shutdown(sig, frame):
        server.close()
        try:
            os.unlink(args.socket)
        except OSError:
            pass
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    while True:
        try:
            client, _ = server.accept()
            t = threading.Thread(target=handle,
                                 args=(client, args.upstream, args.user, target_uid,
                                       not args.insecure_skip_checks),
                                 daemon=True)
            t.start()
        except OSError:
            break


if __name__ == "__main__":
    main()
