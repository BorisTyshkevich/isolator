#!/usr/bin/env python3
"""iso: Unified command for macOS user isolation for AI coding agents.

Usage:
    iso create <name> [options]       Create an isolated user
    iso create --all [options]        Create all users from config
    iso delete <name>                 Delete an isolated user and its home
    iso delete --all                  Delete all users from config
    iso pf                            Apply firewall rules from config
    iso pf --dry-run                  Print firewall rules without loading
    iso list                          List configured users
    iso <user> [command] [args...]     Run command as isolated user (default: bash)
    iso -s <user> [command] [args...] Run via SSH (proper login session, no GUI)
    iso <user> remote [--bg]          Start sandboxed remote session for Claude Desktop
    iso <user> remote --status        Show remote session status
    iso <user> remote --stop          Stop remote session
    iso chrome [--port PORT]          Start agent Chrome (empty profile, default 9222)
    iso chrome --stop                 Stop agent Chrome

Options for create:
    --from USER                       Copy config from USER (default: admin)

Examples:
    iso create acm
    iso acm claude                    # first run: /login to authenticate
    iso chrome                        # start safe browser for agents
    iso acm remote --bg               # connect from Claude Desktop
    iso delete acm
    iso pf
"""

import json
import os
import re
import shlex
import shutil
import socket
import subprocess
import sys
import tomllib
from pathlib import Path

# ── Config ──────────────────────────────────────────────────────────────────

CONFIG_PATH = Path("/etc/isolator/config.toml")
PROFILE_PATH = Path("/etc/isolator/profile")
CLAUDE_MD_PATH = Path("/etc/isolator/CLAUDE.md")
ANCHOR_PATH = Path("/etc/pf.anchors/isolator")
PF_CONF = Path("/etc/pf.conf")
BASE_UID = 600
DOCKER_SUBNET_BASE = "172.30"  # per-user: 172.30.0.0/24, 172.30.1.0/24, ...
ISOLATOR_GROUP = "isolator"  # dedicated group for sandbox users (NOT staff)
NETSHOOT_IMAGE = "nicolaka/netshoot"
SSH_KEY_NAME = "isolator"  # ~/.ssh/isolator (single key for all sandbox users)
SSH_OPTS = ["-o", "StrictHostKeyChecking=no", "-o", "UserKnownHostsFile=/dev/null",
            "-o", "LogLevel=ERROR"]
WORKSPACES_DIR = Path("/Users/Workspaces")
DOCKER_PROXY_DIR = Path("/var/run/isolator-docker")  # root-only system dir
REMOTE_PID_DIR_PATH = Path("/var/run/isolator-remote")  # root-only system dir
DOCKER_PROXY_SCRIPT = Path("/usr/local/bin/docker-proxy-go")

SHELL_RC_FILES = {
    "bash": [".bash_profile", ".bashrc"],
    "zsh": [".zprofile", ".zshrc"],
}

CLAUDE_SETTINGS_OVERRIDES = {
    "defaultMode": "bypassPermissions",
    "skipDangerousModePermissionPrompt": True,
}

CODEX_COPY_FILES = ["auth.json", "AGENTS.md"]
CODEX_COPY_DIRS = ["plugins", "skills", "agents"]

SHARED_TOOLS = [
    {
        "name": "codex",
        "bin": Path("/opt/homebrew/bin/codex"),
        "package_dir": Path("/opt/homebrew/lib/node_modules/@openai/codex"),
    },
]

KEYCHAIN_NAME = "login.keychain-db"

# Extra flags injected when running these commands via `iso <user> <cmd>`
COMMAND_FLAGS = {
    "claude": ["--permission-mode", "bypassPermissions"],
}

# ── Helpers ─────────────────────────────────────────────────────────────────

def run(cmd, check=True):
    """Run a shell command. Show output on failure for easier debugging."""
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        if check or os.environ.get("ISOLATOR_DEBUG"):
            print(f"  {'ERROR' if check else 'WARN'}: {' '.join(cmd)}")
            if r.stdout.strip():
                print(f"         stdout: {r.stdout.strip()}")
            if r.stderr.strip():
                print(f"         stderr: {r.stderr.strip()}")
        if check:
            r.check_returncode()
    return r


def run_as(user, cmd, check=True):
    """Run a command as another user via uid/gid switch."""
    import pwd
    pw = pwd.getpwnam(user)
    home = pw.pw_dir

    def switch_user():
        os.setgid(pw.pw_gid)
        os.setuid(pw.pw_uid)
        os.environ["HOME"] = home

    r = subprocess.run(cmd, capture_output=True, text=True, preexec_fn=switch_user)
    if check and r.returncode != 0:
        print(f"  ERROR (as {user}): {' '.join(cmd)}")
        if r.stderr:
            print(f"         {r.stderr.strip()}")
        r.check_returncode()
    return r


def load_config():
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def get_admin():
    """Get admin username from config (fallback: $USER)."""
    try:
        with open(CONFIG_PATH, "rb") as f:
            return tomllib.load(f).get("admin") or os.environ.get("USER", "")
    except (OSError, tomllib.TOMLDecodeError, PermissionError):
        return os.environ.get("USER", "")


def dscl_read(user, key):
    r = run(["dscl", ".", "-read", f"/Users/{user}", key], check=False)
    if r.returncode != 0:
        return None
    for line in r.stdout.strip().splitlines():
        if line.startswith(f"{key}:"):
            return line.split(":", 1)[1].strip()
    return None


def user_exists(name):
    r = run(["dscl", ".", "-read", f"/Users/{name}"], check=False)
    return r.returncode == 0


def detect_shell(user):
    shell = dscl_read(user, "UserShell") or "/bin/zsh"
    if "zsh" in shell:
        return "zsh", shell
    return "bash", shell


def copy_path(src, dst):
    """Copy file, directory, or symlink."""
    if dst.exists() or dst.is_symlink():
        if dst.is_dir() and not dst.is_symlink():
            shutil.rmtree(dst)
        else:
            dst.unlink()
    if src.is_symlink():
        os.symlink(os.readlink(src), dst)
    elif src.is_dir():
        shutil.copytree(src, dst, symlinks=True)
    else:
        shutil.copy2(src, dst)


VALID_USERNAME_RE = re.compile(r"^[A-Za-z0-9_.-]+$")


def validate_username(name):
    """Reject path-like or otherwise unsafe sandbox user names."""
    if not isinstance(name, str) or not name:
        raise ValueError("invalid sandbox user name: empty")
    if name.startswith("-"):
        raise ValueError(f"invalid sandbox user name {name!r}: cannot start with '-'")
    if "/" in name or "\\" in name or ".." in name or any(ch.isspace() for ch in name):
        raise ValueError(f"invalid sandbox user name {name!r}: must be a simple local account name")
    if not VALID_USERNAME_RE.fullmatch(name):
        raise ValueError(
            f"invalid sandbox user name {name!r}: allowed characters are letters, digits, '_', '.', '-'"
        )
    return name


# ── Create ──────────────────────────────────────────────────────────────────

def next_uid(users):
    used = {u["uid"] for u in users.values() if "uid" in u}
    uid = BASE_UID
    while uid in used:
        uid += 1
    return uid


def add_user_to_config(name, uid):
    entry = f"\n[users.{name}]\nuid = {uid}\n"
    with open(CONFIG_PATH, "a") as f:
        f.write(entry)
    print(f"  Added [users.{name}] (uid={uid}) to {CONFIG_PATH}")


def ensure_isolator_group():
    """Create the isolator group if it doesn't exist (gid 700)."""
    r = run(["dscl", ".", "-read", f"/Groups/{ISOLATOR_GROUP}"], check=False)
    if r.returncode == 0:
        return
    print(f"  Creating group {ISOLATOR_GROUP} (gid=700)")
    run(["dscl", ".", "-create", f"/Groups/{ISOLATOR_GROUP}"])
    run(["dscl", ".", "-create", f"/Groups/{ISOLATOR_GROUP}", "PrimaryGroupID", "700"])


def create_macos_user(name, uid, shell_path):
    home = f"/Users/{name}"
    print(f"  Creating macOS user {name} (uid={uid}, shell={shell_path})")
    ensure_isolator_group()
    run(["dscl", ".", "-create", f"/Users/{name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UserShell", shell_path])
    run(["dscl", ".", "-create", f"/Users/{name}", "RealName", f"Isolator {name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UniqueID", str(uid)])
    # Use isolator group (NOT staff) — staff has access to too many things
    run(["dscl", ".", "-create", f"/Users/{name}", "PrimaryGroupID", "700"])
    run(["dscl", ".", "-create", f"/Users/{name}", "NFSHomeDirectory", home])
    run(["dscl", ".", "-create", f"/Users/{name}", "IsHidden", "1"])


def setup_home(name, admin):
    home = Path(f"/Users/{name}")
    print(f"  Setting up home {home}")
    home.mkdir(mode=0o700, exist_ok=True)
    run(["chown", f"{name}:{ISOLATOR_GROUP}", str(home)])
    run(["chmod", "700", str(home)])
    run(["chmod", "+a",
         f"{admin} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(home)])


def copy_shell_config(name, source_user, shell_type):
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")
    rc_files = SHELL_RC_FILES.get(shell_type, [])

    for rc in rc_files:
        src = source_home / rc
        dst = home / rc
        if src.exists():
            print(f"  Copying {src} -> {dst}")
            shutil.copy2(src, dst)

    source_line = f"\nsource {PROFILE_PATH}\n"
    for rc in rc_files:
        rc_path = home / rc
        if not rc_path.exists():
            rc_path.touch()
        content = rc_path.read_text()
        if str(PROFILE_PATH) not in content:
            print(f"  Appending isolator profile to {rc_path}")
            rc_path.write_text(content + source_line)


ISOLATOR_MARKER = "<!-- isolator-sandbox-instructions -->"


def copy_claude_md(name, source_user):
    """Merge admin's CLAUDE.md with isolator sandbox instructions.

    If source user has ~/.claude/CLAUDE.md, copy it and append isolator
    instructions (marked with a comment so we can replace on re-run).
    If no source CLAUDE.md, use isolator template only.
    """
    if not CLAUDE_MD_PATH.exists():
        return
    home = Path(f"/Users/{name}")
    claude_dir = home / ".claude"
    claude_dir.mkdir(exist_ok=True)
    dst = claude_dir / "CLAUDE.md"

    # Source user's CLAUDE.md (admin's custom instructions)
    source_md = Path(f"/Users/{source_user}/.claude/CLAUDE.md")
    if source_md.exists():
        content = source_md.read_text()
        # Strip any previous isolator block
        if ISOLATOR_MARKER in content:
            content = content[:content.index(ISOLATOR_MARKER)].rstrip()
    else:
        content = ""

    # Append isolator sandbox instructions
    isolator_block = CLAUDE_MD_PATH.read_text()
    merged = f"{content}\n\n{ISOLATOR_MARKER}\n{isolator_block}" if content else isolator_block
    dst.write_text(merged)
    print(f"  Merged CLAUDE.md (admin + isolator sandbox instructions)")


def copy_claude_config(name, source_user):
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")

    claude_dir = home / ".claude"
    claude_dir.mkdir(exist_ok=True)

    # settings.json
    src_settings = source_home / ".claude" / "settings.json"
    dst_settings = claude_dir / "settings.json"
    settings = {}
    if src_settings.exists():
        print(f"  Copying {src_settings}")
        settings = json.loads(src_settings.read_text())
    settings.update(CLAUDE_SETTINGS_OVERRIDES)
    dst_settings.write_text(json.dumps(settings, indent=2) + "\n")

    # .claude.json
    src_claude_json = source_home / ".claude.json"
    dst_claude_json = home / ".claude.json"
    CLAUDE_JSON_KEYS = [
        "mcpServers", "oauthAccount", "hasCompletedOnboarding",
        "lastOnboardingVersion", "numStartups", "firstStartTime",
        "migrationVersion", "opusProMigrationComplete",
        "sonnet45MigrationComplete", "sonnet1m45MigrationComplete",
        "opus45MigrationComplete", "thinkingMigrationComplete",
    ]
    claude_json_data = {}
    if src_claude_json.exists():
        try:
            data = json.loads(src_claude_json.read_text())
            for key in CLAUDE_JSON_KEYS:
                if key in data:
                    claude_json_data[key] = data[key]
            if "mcpServers" in claude_json_data:
                print(f"  Copying MCP servers: {list(claude_json_data['mcpServers'].keys())}")
            if "oauthAccount" in claude_json_data:
                print(f"  Copying OAuth account: {claude_json_data['oauthAccount'].get('emailAddress', '?')}")
        except (json.JSONDecodeError, KeyError):
            pass
    # Pre-trust the user's home directory
    home_path = f"/Users/{name}"
    claude_json_data["projects"] = {
        home_path: {
            "allowedTools": [],
            "hasTrustDialogAccepted": True,
        }
    }
    dst_claude_json.write_text(json.dumps(claude_json_data, indent=2) + "\n")

    # skills symlink
    src_skills = source_home / ".claude" / "skills"
    dst_skills = claude_dir / "skills"
    if src_skills.is_symlink():
        target = os.readlink(src_skills)
        print(f"  Linking skills -> {target}")
        if dst_skills.exists() or dst_skills.is_symlink():
            dst_skills.unlink()
        os.symlink(target, dst_skills)

    # plugins — copy and fix hardcoded paths in JSON configs
    src_plugins = source_home / ".claude" / "plugins"
    dst_plugins = claude_dir / "plugins"
    if src_plugins.is_dir():
        print(f"  Copying plugins/")
        if dst_plugins.exists():
            shutil.rmtree(dst_plugins)
        shutil.copytree(src_plugins, dst_plugins)
        # Rewrite source-user paths to sandbox-user paths in JSON configs
        for json_file in dst_plugins.glob("*.json"):
            try:
                content = json_file.read_text()
                if str(source_home) in content:
                    content = content.replace(str(source_home), str(home))
                    json_file.write_text(content)
            except (OSError, UnicodeDecodeError):
                pass


CODEX_CONFIG_OVERRIDES = {
    "approval_policy": "never",
    "sandbox_mode": "danger-full-access",
}


def _toml_escape(s):
    """Escape a string for TOML (basic strings only)."""
    return s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


def _toml_emit_value(v):
    """Emit a TOML scalar/array. Doesn't handle nested tables."""
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int) or isinstance(v, float):
        return str(v)
    if isinstance(v, str):
        return f'"{_toml_escape(v)}"'
    if isinstance(v, list):
        return "[" + ", ".join(_toml_emit_value(x) for x in v) + "]"
    raise TypeError(f"unsupported TOML value type: {type(v).__name__}")


def _toml_emit(data, prefix=""):
    """Serialize a TOML document. Tables-of-tables, etc.

    Stdlib has no TOML writer, so this is a small custom emitter.
    Handles: scalars, arrays of scalars, nested tables, arrays of tables.
    """
    out = []
    # First emit scalars at this level
    scalars = {k: v for k, v in data.items() if not isinstance(v, dict)
               and not (isinstance(v, list) and v and all(isinstance(x, dict) for x in v))}
    for k, v in scalars.items():
        out.append(f"{k} = {_toml_emit_value(v)}")
    # Then nested tables
    for k, v in data.items():
        if isinstance(v, dict):
            section = f"{prefix}{k}" if not prefix else f"{prefix}.{k}"
            out.append(f"\n[{section}]")
            out.append(_toml_emit(v, section))
        elif isinstance(v, list) and v and all(isinstance(x, dict) for x in v):
            section = f"{prefix}{k}" if not prefix else f"{prefix}.{k}"
            for item in v:
                out.append(f"\n[[{section}]]")
                out.append(_toml_emit(item, section))
    return "\n".join(line for line in out if line)


def sanitize_codex_config(src, dst):
    """Parse codex config.toml, drop project trust entries, override bypass mode."""
    try:
        with open(src, "rb") as f:
            data = tomllib.load(f)
    except (OSError, tomllib.TOMLDecodeError) as e:
        print(f"  ERROR parsing {src}: {e}")
        return False

    # Drop [projects.*] trust entries
    removed_projects = 0
    if "projects" in data and isinstance(data["projects"], dict):
        removed_projects = len(data["projects"])
        del data["projects"]

    # Override bypass mode keys
    for k, v in CODEX_CONFIG_OVERRIDES.items():
        data[k] = v

    dst.write_text(_toml_emit(data) + "\n")
    print(f"  Copying {src} -> {dst} (dropped {removed_projects} project trust entries, set bypass mode)")
    return True


def copy_codex_config(name, source_user):
    home = Path(f"/Users/{name}")
    source_home = Path(f"/Users/{source_user}")
    src_codex = source_home / ".codex"
    dst_codex = home / ".codex"
    if not src_codex.exists():
        print("  No ~/.codex found in source user, skipping Codex config")
        return
    dst_codex.mkdir(exist_ok=True)
    src_config = src_codex / "config.toml"
    if src_config.exists():
        sanitize_codex_config(src_config, dst_codex / "config.toml")
    for rel in CODEX_COPY_FILES:
        src = src_codex / rel
        dst = dst_codex / rel
        if src.exists() or src.is_symlink():
            print(f"  Copying {src} -> {dst}")
            copy_path(src, dst)
    for rel in CODEX_COPY_DIRS:
        src = src_codex / rel
        dst = dst_codex / rel
        if src.exists() or src.is_symlink():
            print(f"  Copying {src} -> {dst}")
            copy_path(src, dst)


def ensure_shared_tool_access():
    for tool in SHARED_TOOLS:
        bin_path = tool["bin"]
        package_dir = tool["package_dir"]
        if not bin_path.exists():
            continue
        if not package_dir.exists():
            print(f"  WARNING: {tool['name']} binary exists but package dir {package_dir} is missing")
            continue
        print(f"  Ensuring shared access to {tool['name']} in {package_dir}")
        run(["chmod", "-R", "a+rX", str(package_dir)])
        if bin_path.is_symlink():
            run(["chmod", "-h", "755", str(bin_path)], check=False)


# ── Auth ────────────────────────────────────────────────────────────────────
# Claude Code auth: user runs /login on first use → stores in macOS keychain
# with ACL that only allows Claude Code to read. No credentials copied by iso.
#
# Other env vars (OPENAI_API_KEY, etc.): injected from config key files → .env

def create_empty_keychain(name):
    """Create an empty default keychain so Claude Code can store credentials.

    Uses a fixed password ("isolator") since the keychain is protected by
    filesystem permissions (chmod 700 on home). The password isn't a
    security boundary — the keychain entry ACLs are.
    """
    home = Path(f"/Users/{name}")
    kc_dir = home / "Library" / "Keychains"
    kc_file = kc_dir / KEYCHAIN_NAME

    if kc_file.exists():
        return  # already exists

    kc_dir.mkdir(parents=True, exist_ok=True)
    run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(home / "Library")])
    run_as(name, ["security", "create-keychain", "-p", "isolator", str(kc_file)])
    run_as(name, ["security", "default-keychain", "-s", str(kc_file)])
    run_as(name, ["security", "list-keychains", "-s", str(kc_file)])
    run_as(name, ["security", "set-keychain-settings", str(kc_file)])  # no auto-lock
    run_as(name, ["security", "unlock-keychain", "-p", "isolator", str(kc_file)])
    print(f"  Created empty default keychain")


def inject_auth_keyfiles(name, user_config):
    """Inject env vars from key files defined in config [users.<name>.auth]."""
    auth = user_config.get("auth", {})
    if not auth:
        return
    home = Path(f"/Users/{name}")
    env_file = home / ".env"
    lines = ["# Isolator auth (from config key files)"]
    for var, keyfile in auth.items():
        keypath = Path(keyfile)
        if not keypath.exists():
            print(f"  WARNING: key file {keypath} not found, skipping {var}")
            continue
        value = keypath.read_text().strip()
        lines.append(f'export {var}="{value}"')
        print(f"  Injecting {var} from {keypath}")
    if len(lines) > 1:
        env_file.write_text("\n".join(lines) + "\n")


# ── Ownership ───────────────────────────────────────────────────────────────

def create_skeleton(name, admin):
    home = Path(f"/Users/{name}")
    for d in [".local/bin", ".local/lib", ".cache", "tmp"]:
        (home / d).mkdir(parents=True, exist_ok=True)
    # Shared workspaces root
    WORKSPACES_DIR.mkdir(mode=0o775, exist_ok=True)
    # /Users/Workspaces is root-only writable; admin uses ACL to read,
    # per-user dirs are created and owned by their respective sandbox users
    run(["chown", "root:wheel", str(WORKSPACES_DIR)], check=False)
    run(["chmod", "755", str(WORKSPACES_DIR)], check=False)
    # Per-user workspace
    user_ws = WORKSPACES_DIR / name
    user_ws.mkdir(exist_ok=True)
    run(["chown", f"{name}:{ISOLATOR_GROUP}", str(user_ws)])
    run(["chmod", "700", str(user_ws)])
    # Sandbox user gets full inheriting ACE on their own workspace so files
    # created there by anyone (e.g. admin bvt) remain writable by the user.
    run(["chmod", "+a",
         f"{name} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(user_ws)])
    run(["chmod", "+a",
         f"{admin} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(user_ws)])
    print(f"  Workspace: {user_ws}")


def set_ownership(name):
    home = Path(f"/Users/{name}")

    # Config files: root-owned, world-readable (no secrets here)
    for f in [".bash_profile", ".bashrc", ".zprofile", ".zshrc",
              ".claude/CLAUDE.md", ".claude/settings.json",
              ".claude.json", ".codex/config.toml", ".codex/AGENTS.md"]:
        path = home / f
        if path.exists():
            run(["chown", "root:wheel", str(path)])
            run(["chmod", "444", str(path)])

    # .env contains secrets — only the user can read it
    env_file = home / ".env"
    if env_file.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(env_file)])
        run(["chmod", "400", str(env_file)])

    claude_dir = home / ".claude"
    if claude_dir.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(claude_dir)])
        run(["chmod", "700", str(claude_dir)])

    # plugins — user-owned (Claude Code clones marketplaces here)
    plugins_dir = home / ".claude" / "plugins"
    if plugins_dir.exists():
        run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(plugins_dir)])
        run(["chmod", "-R", "755", str(plugins_dir)])

    cj = home / ".claude.json"
    if cj.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(cj)])
        run(["chmod", "600", str(cj)])

    codex_dir = home / ".codex"
    if codex_dir.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(codex_dir)])
        run(["chmod", "700", str(codex_dir)])

    codex_auth = codex_dir / "auth.json"
    if codex_auth.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(codex_auth)])
        run(["chmod", "600", str(codex_auth)])

    for rel in [".codex/plugins", ".codex/skills", ".codex/agents"]:
        path = home / rel
        if path.exists():
            if path.is_symlink():
                run(["chown", "-h", "root:wheel", str(path)])
            else:
                run(["chown", "-R", "root:wheel", str(path)])
                run(["chmod", "-R", "755", str(path)])

    for d in [".local", ".cache", "tmp"]:
        path = home / d
        if path.exists():
            run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(path)])


def ssh_key_path(admin):
    """Return path to admin's isolator SSH private key."""
    return Path(f"/Users/{admin}/.ssh/{SSH_KEY_NAME}")


def setup_ssh_key(name, admin):
    """Generate admin keypair (once) and install public key for sandbox user."""
    admin_home = Path(f"/Users/{admin}")
    user_home = Path(f"/Users/{name}")

    priv_key = admin_home / ".ssh" / SSH_KEY_NAME

    # Generate keypair if it doesn't exist
    if not priv_key.exists():
        (admin_home / ".ssh").mkdir(mode=0o700, exist_ok=True)
        run(["ssh-keygen", "-t", "ed25519", "-f", str(priv_key),
             "-N", "", "-q", "-C", f"isolator@{subprocess.run(['hostname', '-s'], capture_output=True, text=True).stdout.strip()}"])
        run(["chmod", "600", str(priv_key)])
        run(["chown", f"{admin}:staff", str(priv_key), str(priv_key.with_suffix(".pub"))])
        print(f"  Generated SSH keypair: {priv_key}")

    pub_key = priv_key.with_suffix(".pub").read_text().strip()

    # Install public key in sandbox user's authorized_keys
    user_ssh = user_home / ".ssh"
    user_ssh.mkdir(exist_ok=True)
    auth_keys = user_ssh / "authorized_keys"
    auth_keys.write_text(pub_key + "\n")
    run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(user_ssh)])
    run(["chmod", "700", str(user_ssh)])
    run(["chmod", "600", str(auth_keys)])

    # Add to SSH service ACL group (created by macOS when Remote Login enabled)
    r = run(["dscl", ".", "-read", "/Groups/com.apple.access_ssh"], check=False)
    if r.returncode != 0:
        print(f"  WARNING: SSH ACL group not found — Remote Login may not be enabled")
        print(f"           SSH mode (iso -s) won't work until you enable Remote Login")
    else:
        run(["dscl", ".", "-append", "/Groups/com.apple.access_ssh",
             "GroupMembership", name])
        print(f"  SSH key installed, added to SSH access group")


def exclude_from_backup(name):
    """Exclude user home and keychain password from Time Machine."""
    home = Path(f"/Users/{name}")
    run(["tmutil", "addexclusion", str(home)], check=False)
    print(f"  Excluded from Time Machine backup")


def user_subnet(config, name):
    """Return the Docker subnet for a user based on position in config."""
    users = list(config.get("users", {}).keys())
    idx = users.index(name) if name in users else len(users)
    return f"{DOCKER_SUBNET_BASE}.{idx}.0/24"


def create_docker_network(name, config):
    """Create a per-user Docker network with a dedicated subnet."""
    net_name = f"iso-{name}"
    subnet = user_subnet(config, name)
    # Check if network exists
    r = run(["docker", "network", "inspect", net_name], check=False)
    if r.returncode == 0:
        print(f"  Docker network {net_name} already exists")
        return
    run(["docker", "network", "create", f"--subnet={subnet}", net_name], check=False)
    print(f"  Created Docker network {net_name} ({subnet})")


# ── Create command ──────────────────────────────────────────────────────────

def cmd_create(name, config, from_user=None):
    """Create one isolated user."""
    name = validate_username(name)
    users = config.get("users", {})
    admin = config["admin"]

    if name not in users:
        uid = next_uid(users)
        add_user_to_config(name, uid)
        users[name] = {"uid": uid}

    user_config = users[name]
    uid = user_config["uid"]
    source = from_user or user_config.get("from", admin)

    print(f"\n=== Creating {name} (uid={uid}, from={source}) ===")

    admin_home = Path(f"/Users/{admin}")
    if admin_home.stat().st_mode & 0o077:
        print(f"  Locking admin home {admin_home} to 700")
        run(["chmod", "700", str(admin_home)])

    # Ensure isolator group exists (idempotent) — needed even if user exists
    ensure_isolator_group()

    if user_exists(name):
        print(f"  User {name} already exists, skipping dscl creation")
    else:
        shell_type, shell_path = detect_shell(source)
        create_macos_user(name, uid, shell_path)

    shell_type, shell_path = detect_shell(source)

    setup_home(name, admin)
    copy_shell_config(name, source, shell_type)
    copy_claude_md(name, source)
    copy_claude_config(name, source)
    copy_codex_config(name, source)
    inject_auth_keyfiles(name, user_config)
    create_empty_keychain(name)
    create_skeleton(name, admin)
    create_docker_network(name, config)
    setup_ssh_key(name, admin)
    ensure_shared_tool_access()
    set_ownership(name)
    exclude_from_backup(name)

    print(f"=== Done: {name} ===")


# ── Delete command ──────────────────────────────────────────────────────────

def cmd_delete(name):
    """Delete one isolated user and its home directory."""
    name = validate_username(name)
    home = Path(f"/Users/{name}")

    print(f"\n=== Deleting {name} ===")

    if user_exists(name):
        kc_file = home / "Library" / "Keychains" / KEYCHAIN_NAME
        if kc_file.exists():
            run(["security", "delete-keychain", str(kc_file)], check=False)
        print(f"  Removing macOS user {name}")
        run(["dscl", ".", "-delete", f"/Users/{name}"])
    else:
        print(f"  User {name} does not exist in directory")

    if home.exists():
        print(f"  Removing {home}")
        shutil.rmtree(home)
    else:
        print(f"  Home {home} does not exist")

    print(f"=== Done: {name} ===")


# ── Firewall command ────────────────────────────────────────────────────────

def resolve_hosts(hosts):
    ips = set()
    for host in hosts:
        try:
            results = socket.getaddrinfo(host, 443, socket.AF_INET, socket.SOCK_STREAM)
            for _, _, _, _, addr in results:
                ips.add(addr[0])
        except socket.gaierror as e:
            print(f"  WARNING: cannot resolve {host}: {e}")
    return sorted(ips)


def is_unrestricted(user_config):
    """Check if user has wildcard hosts (unrestricted network)."""
    return "*" in user_config.get("hosts", [])


def should_log(user_config):
    """Check if user has logging enabled."""
    return user_config.get("log", False)


def generate_anchor(config):
    users = config.get("users", {})
    global_cfg = config.get("global", {})
    global_hosts = global_cfg.get("hosts", [])
    global_subnets = global_cfg.get("subnets", [])
    lines = ["# Generated by isolator", ""]
    restricted_uids = []

    for name, user_config in users.items():
        uid = user_config["uid"]
        if is_unrestricted(user_config):
            print(f"  {name} (uid={uid}): unrestricted network")
            continue
        restricted_uids.append(uid)
        hosts = user_config.get("hosts", []) + global_hosts
        subnets = user_config.get("subnets", []) + global_subnets
        log = should_log(user_config)
        print(f"  Resolving hosts for {name} (uid={uid}){'  [logging]' if log else ''}...")
        for h in hosts:
            print(f"    {h}")
        ips = resolve_hosts(hosts)
        if subnets:
            print(f"    subnets: {', '.join(subnets)}")
        print(f"    -> {len(ips)} IPs + {len(subnets)} subnets")
        entries = sorted(ips) + subnets
        if entries:
            ip_list = ", ".join(entries)
            lines.append(f"table <{name}-allowed> {{ {ip_list} }}")

    lines.append("")

    if not restricted_uids:
        print("No restricted users, skipping pf rules")
        return ""

    uid_list = " ".join(str(u) for u in restricted_uids)
    log_kw = "log " if any(should_log(users[n]) for n in users if users[n]["uid"] in restricted_uids) else ""
    lines.append(f"block {log_kw}out proto tcp from any to any user {{ {uid_list} }}")
    lines.append(f"block {log_kw}out proto udp from any to any user {{ {uid_list} }}")
    lines.append("")

    for name, user_config in users.items():
        uid = user_config["uid"]
        if is_unrestricted(user_config):
            continue
        log_kw = "log " if should_log(user_config) else ""
        extra_ports = user_config.get("extra_ports", [])
        ports = " ".join(str(p) for p in [443] + extra_ports)
        port_spec = ports if len(extra_ports) == 0 else f"{{ {ports} }}"
        # macOS pf: user keyword must come after address/port specifiers
        lines.append(f"pass {log_kw}out proto tcp from any to <{name}-allowed> port {port_spec} user {uid}")

    lines.append("")
    # Allow all localhost — local services (Chrome DevTools, MCP servers, etc.)
    lines.append(f"pass out proto tcp from any to 127.0.0.1 user {{ {uid_list} }}")
    lines.append(f"pass out proto udp from any to 127.0.0.1 user {{ {uid_list} }}")
    lines.append("")
    return "\n".join(lines)


def ensure_pf_conf():
    """Add isolator anchor to /etc/pf.conf if missing. fcntl-locked."""
    import fcntl
    # Open for read+write, create if missing, and hold an exclusive lock
    # for the entire read-modify-write sequence
    fd = os.open(PF_CONF, os.O_RDWR | os.O_CREAT, 0o644)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        with os.fdopen(fd, "r+") as f:
            content = f.read()
            if 'anchor "isolator"' not in content:
                print(f"  Adding anchor to {PF_CONF}")
                additions = '\nanchor "isolator"\nload anchor "isolator" from "/etc/pf.anchors/isolator"\n'
                f.write(additions)
    except Exception:
        os.close(fd)
        raise


def generate_docker_iptables(config):
    """Generate iptables rules for Docker container egress filtering."""
    users = config.get("users", {})
    global_hosts = config.get("global", {}).get("hosts", [])
    rules = []

    # Flush DOCKER-USER chain
    # Build into staging chain DOCKER-USER-NEW, then atomic swap.
    # Avoids the brief window where DOCKER-USER is empty and traffic flows free.
    rules.append("iptables -N DOCKER-USER-NEW 2>/dev/null || iptables -F DOCKER-USER-NEW")

    for name, user_config in users.items():
        subnet = user_subnet(config, name)
        log = should_log(user_config)

        if is_unrestricted(user_config):
            if log:
                rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j LOG --log-prefix 'iso-{name}: '")
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j ACCEPT")
            continue

        hosts = user_config.get("hosts", []) + global_hosts
        ips = resolve_hosts(hosts)

        rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -d {subnet} -j ACCEPT")
        for ip in ips:
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -d {ip} -p tcp --dport 443 -j ACCEPT")
        if log:
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j LOG --log-prefix 'iso-{name}-drop: '")
        rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j DROP")

    # Block default bridge — sandboxed agents must use iso-<user>
    rules.append("iptables -A DOCKER-USER-NEW -s 172.17.0.0/16 -j DROP")
    # Default: allow other Docker traffic (admin's containers)
    rules.append("iptables -A DOCKER-USER-NEW -j ACCEPT")

    # Atomic swap: rename old → backup, new → DOCKER-USER, drop backup
    rules.append("iptables -E DOCKER-USER DOCKER-USER-OLD 2>/dev/null || true")
    rules.append("iptables -E DOCKER-USER-NEW DOCKER-USER")
    rules.append("iptables -F DOCKER-USER-OLD 2>/dev/null || true")
    rules.append("iptables -X DOCKER-USER-OLD 2>/dev/null || true")
    return rules


def apply_docker_iptables(rules, dry_run=False):
    """Apply iptables rules inside the Docker VM via nsenter."""
    script = " && ".join(rules)

    if dry_run:
        print("\n--- Docker iptables rules (dry run) ---")
        for r in rules:
            print(f"  {r}")
        return

    print("\n  Applying Docker iptables rules...")
    # Ensure netshoot image is available
    run(["docker", "pull", "-q", NETSHOOT_IMAGE], check=False)
    r = subprocess.run(
        ["docker", "run", "--rm", "--privileged", "--pid=host", "--network=host",
         NETSHOOT_IMAGE, "sh", "-c", f"nsenter -t 1 -n sh -c '{script}'"],
        capture_output=True, text=True)
    if r.returncode != 0:
        print(f"  WARNING: Docker iptables failed: {r.stderr.strip()}")
    else:
        print("  Docker iptables rules loaded")


def cmd_pf(config, dry_run=False):
    # macOS pf rules
    anchor = generate_anchor(config)
    if not anchor:
        return
    if dry_run:
        print("\n--- Generated pf anchor (dry run) ---")
        print(anchor)
    else:
        print(f"\n  Writing {ANCHOR_PATH}")
        ANCHOR_PATH.parent.mkdir(parents=True, exist_ok=True)
        ANCHOR_PATH.write_text(anchor)
        ensure_pf_conf()
        print("  Loading pf rules...")
        r = subprocess.run(["pfctl", "-ef", str(PF_CONF)],
                           capture_output=True, text=True)
        if r.returncode != 0:
            print(f"  ERROR: pfctl failed: {r.stderr}")
            sys.exit(1)
        print("  pf rules loaded")

    # Docker iptables rules
    docker_rules = generate_docker_iptables(config)
    apply_docker_iptables(docker_rules, dry_run)


# ── Run command ─────────────────────────────────────────────────────────────

def proxy_tcp_port(user_config):
    """Deterministic per-user TCP port for the docker-proxy TLS listener.

    Sandbox UIDs start at 600. Map to ports 40000+: altinity(606) -> 40006.
    Predictable so the user's profile/env can hardcode it without lookup.
    """
    return 40000 + (user_config["uid"] - BASE_UID)


def ensure_proxy_tls_certs(user):
    """Generate the TLS cert tree for the docker-proxy TCP listener if missing.

    Cert tree lives at /Users/<user>/.isolator-docker-proxy/, owned by the
    user (mode 0700). testcontainers reads DOCKER_CERT_PATH from this dir.

    Returns the cert dir path (Path).
    """
    cert_dir = Path(f"/Users/{user}/.isolator-docker-proxy")
    ca_file = cert_dir / "ca.pem"

    if ca_file.exists():
        return cert_dir

    # mkdir + chown to user, then run --init-tls as root (writes files)
    subprocess.run(["sudo", "mkdir", "-p", str(cert_dir)], capture_output=True)
    subprocess.run(["sudo", "chown", f"{user}:isolator", str(cert_dir)],
                   capture_output=True)
    subprocess.run(["sudo", "chmod", "0700", str(cert_dir)], capture_output=True)
    r = subprocess.run([
        "sudo", str(DOCKER_PROXY_SCRIPT),
        "--user", user,
        "--tls-cert-dir", str(cert_dir),
        "--init-tls",
    ], capture_output=True, text=True)
    if r.returncode != 0:
        print(f"  WARNING: TLS cert init failed: {r.stderr.strip()}")
        return None
    # Cert files were written as root; chown them to user.
    subprocess.run(["sudo", "chown", "-R", f"{user}:isolator", str(cert_dir)],
                   capture_output=True)
    return cert_dir


def ensure_docker_proxy(user):
    """Start per-user Docker proxy if not already running."""
    # Create proxy dir as root if needed (only root can write to /var/run)
    if not DOCKER_PROXY_DIR.exists():
        subprocess.run(["sudo", "mkdir", "-p", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
        subprocess.run(["sudo", "chown", "root:wheel", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
        # 711: traverse-only (sandbox users can stat /var/run/isolator-docker/<user>.sock
        # if they know the name, but can't list other users' sockets)
        subprocess.run(["sudo", "chmod", "711", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
    else:
        # Verify ownership — refuse to use a hijacked dir
        st = DOCKER_PROXY_DIR.stat()
        if st.st_uid != 0:
            print(f"FATAL: {DOCKER_PROXY_DIR} not root-owned (uid={st.st_uid})")
            sys.exit(1)

    sock = DOCKER_PROXY_DIR / f"{user}.sock"
    pid_file = DOCKER_PROXY_DIR / f"{user}.pid"
    log_file = DOCKER_PROXY_DIR / f"{user}.log"

    # Check if already running (verify pid belongs to docker-proxy)
    if pid_file.exists():
        try:
            # PID file is root-owned (created via sudo tee), read via sudo
            r = subprocess.run(["sudo", "cat", str(pid_file)],
                               capture_output=True, text=True)
            pid = int(r.stdout.strip())
            r = subprocess.run(["ps", "-p", str(pid), "-o", "command="],
                               capture_output=True, text=True)
            if "docker-proxy" in r.stdout and sock.exists():
                return "ready"
        except (ValueError, OSError):
            pass
        subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
        subprocess.run(["sudo", "rm", "-f", str(sock)], capture_output=True)

    # Find upstream Docker socket — use OrbStack socket directly,
    # NOT /var/run/docker.sock (which would be accessible to sandbox users)
    admin = get_admin()
    upstream = Path(f"/Users/{admin}/.orbstack/run/docker.sock")
    if not upstream.exists():
        return "unavailable"  # no Docker / no OrbStack

    # Set up TLS cert tree + compute TCP port for the in-container listener.
    # Used by tools (e.g. testcontainers' Ryuk) that need to reach the proxy
    # from inside a container — bind-mounting a host Unix socket into a VM
    # container doesn't work on macOS (the file is visible but connect() is
    # refused), so we expose a TLS-protected loopback port instead.
    config = load_config()
    user_cfg = config.get("users", {}).get(user)
    cert_dir = None
    tcp_port = None
    if user_cfg and "uid" in user_cfg:
        tcp_port = proxy_tcp_port(user_cfg)
        cert_dir = ensure_proxy_tls_certs(user)

    # Start the proxy in a single sudo invocation so the password prompt and
    # the privileged launch share the same tty/ticket context.
    proxy_argv = [
        shlex.quote(str(DOCKER_PROXY_SCRIPT)),
        "--user", shlex.quote(user),
        "--socket", shlex.quote(str(sock)),
        "--upstream", shlex.quote(str(upstream)),
    ]
    if tcp_port and cert_dir:
        proxy_argv += [
            "--tcp-port", str(tcp_port),
            "--tls-cert-dir", shlex.quote(str(cert_dir)),
        ]
    proxy_cmd = " ".join(proxy_argv)
    subprocess.run(["sudo", "rm", "-f", str(log_file)], capture_output=True)
    redirect = f" >>{shlex.quote(str(log_file))} 2>&1"
    launch_cmd = (
        f"rm -f {shlex.quote(str(sock))} {shlex.quote(str(pid_file))}; "
        f"nohup {proxy_cmd}{redirect} & echo $! > {shlex.quote(str(pid_file))}"
    )
    r = subprocess.run(["sudo", "sh", "-c", launch_cmd], capture_output=True, text=True)
    if r.returncode != 0:
        print("  WARNING: docker-proxy launch failed")
        if r.stderr.strip():
            print(f"           {r.stderr.strip()}")
        return "failed"

    def read_proxy_log():
        r = subprocess.run(["sudo", "cat", str(log_file)], capture_output=True, text=True)
        if r.returncode != 0:
            return ""
        return r.stdout.strip()

    # Wait briefly for the socket to appear, but fail fast if the process dies.
    import time
    for _ in range(10):  # up to 1 second
        if sock.exists():
            return "ready"
        try:
            r = subprocess.run(["sudo", "cat", str(pid_file)], capture_output=True, text=True)
            pid = int(r.stdout.strip())
            r = subprocess.run(["ps", "-p", str(pid), "-o", "command="],
                               capture_output=True, text=True)
            if "docker-proxy" not in r.stdout:
                break
        except (ValueError, OSError):
            break
        time.sleep(0.1)

    log_output = read_proxy_log()
    subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
    subprocess.run(["sudo", "rm", "-f", str(sock)], capture_output=True)
    if log_output:
        print("  docker-proxy output:")
        for line in log_output.splitlines()[-10:]:
            print(f"    {line}")
    return "failed"


def build_ssh_cmd(user, command, extra, args, cwd=None):
    """Build SSH command to run as sandboxed user."""
    admin = get_admin()
    priv_key = ssh_key_path(admin)

    parts = []
    if cwd:
        parts.append(f"cd {shlex.quote(cwd)}")
    quoted = " ".join(shlex.quote(a) for a in [command] + extra + args)
    parts.append(f"exec {quoted}")

    remote = " && ".join(parts)
    return ["ssh", "-t", "-i", str(priv_key)] + SSH_OPTS + [
        f"{user}@127.0.0.1", remote]


def cmd_run(user, command, args, use_ssh=False):
    """Run a command as an isolated user. Default: sudo. With -s: SSH."""
    user = validate_username(user)
    docker_status = ensure_docker_proxy(user)
    extra = COMMAND_FLAGS.get(command, [])
    user_ws = WORKSPACES_DIR / user
    cwd = str(user_ws) if user_ws.exists() else None

    if docker_status == "failed":
        print(f"WARNING: Docker proxy for {user} failed to start.")
        print(f"         expected socket: {DOCKER_PROXY_DIR / f'{user}.sock'}")
        print("         shell will start without DOCKER_HOST; fix sudo/OrbStack and retry.")

    if use_ssh:
        admin = get_admin()
        priv_key = ssh_key_path(admin)
        if priv_key.exists():
            os.execvp("ssh", build_ssh_cmd(user, command, extra, args, cwd))
        else:
            print("SSH key not found. Run 'iso create' first or use sudo mode (without -s).")
            sys.exit(1)
    else:
        # Sudo mode: inherits admin's GUI session (open, Chrome, etc. work)
        all_args = [command] + extra + args
        if cwd:
            quoted = " ".join(shlex.quote(a) for a in all_args)
            shell_cmd = f"cd {shlex.quote(cwd)} && exec {quoted}"
            os.execvp("sudo", ["sudo", "-u", user, "-i", "bash", "-c", shell_cmd])
        else:
            os.execvp("sudo", ["sudo", "-u", user, "-i"] + all_args)


# ── Remote command ──────────────────────────────────────────────────────────

REMOTE_PID_DIR = REMOTE_PID_DIR_PATH


def remote_pid_file(user):
    user = validate_username(user)
    return REMOTE_PID_DIR / f"{user}.pid"


def cmd_remote(user, args):
    """Manage a sandboxed remote Claude session for Claude Desktop."""
    user = validate_username(user)
    if "--stop" in args:
        pid_file = remote_pid_file(user)
        if not pid_file.exists():
            print(f"No remote session for {user}")
            return
        r = subprocess.run(["sudo", "cat", str(pid_file)],
                           capture_output=True, text=True)
        try:
            pid = int(r.stdout.strip())
        except ValueError:
            print(f"Invalid pid file for {user}")
            return
        # Verify the PID belongs to our user (prevent killing arbitrary process)
        r = subprocess.run(["ps", "-p", str(pid), "-o", "user=,command="],
                           capture_output=True, text=True)
        if user not in r.stdout or "claude" not in r.stdout:
            print(f"PID {pid} doesn't look like a session for {user}, refusing to kill")
            subprocess.run(["sudo", "rm", str(pid_file)], capture_output=True)
            return
        subprocess.run(["sudo", "kill", str(pid)], capture_output=True)
        subprocess.run(["sudo", "rm", str(pid_file)], capture_output=True)
        print(f"Stopped remote session for {user} (pid {pid})")
        return

    if "--status" in args:
        pid_file = remote_pid_file(user)
        if not pid_file.exists():
            print(f"No remote session for {user}")
            return
        # PID file is root-owned (dir is 700)
        r = subprocess.run(["sudo", "cat", str(pid_file)],
                           capture_output=True, text=True)
        try:
            pid = int(r.stdout.strip())
        except ValueError:
            print(f"Invalid pid file for {user}")
            return
        r = subprocess.run(["ps", "-p", str(pid)], capture_output=True)
        if r.returncode == 0:
            print(f"Remote session for {user}: running (pid {pid})")
        else:
            print(f"Remote session for {user}: not running (stale pid file)")
            subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
        return

    bg = "--bg" in args

    admin = get_admin()
    priv_key = ssh_key_path(admin)
    if priv_key.exists():
        user_ws = WORKSPACES_DIR / user
        cwd = str(user_ws) if user_ws.exists() else None
        remote_cmd = build_ssh_cmd(user, "claude",
                                   ["--remote", "--permission-mode", "bypassPermissions"], [],
                                   cwd)
    else:
        remote_cmd = ["sudo", "-u", user, "-i",
                      "claude", "--remote", "--permission-mode", "bypassPermissions"]

    if bg:
        if not REMOTE_PID_DIR.exists():
            subprocess.run(["sudo", "mkdir", "-p", str(REMOTE_PID_DIR)],
                           capture_output=True)
            subprocess.run(["sudo", "chown", "root:wheel", str(REMOTE_PID_DIR)],
                           capture_output=True)
            subprocess.run(["sudo", "chmod", "700", str(REMOTE_PID_DIR)],
                           capture_output=True)
        else:
            # Refuse hijacked dir
            st = REMOTE_PID_DIR.stat()
            if st.st_uid != 0:
                print(f"FATAL: {REMOTE_PID_DIR} not root-owned (uid={st.st_uid})")
                sys.exit(1)
        proc = subprocess.Popen(
            remote_cmd,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        pid_file = remote_pid_file(user)
        # Write via sudo since dir is root-owned
        subprocess.run(["sudo", "tee", str(pid_file)],
                       input=str(proc.pid), text=True, capture_output=True)
        print(f"Started remote session for {user} in background (pid {proc.pid})")
        # Print first few lines to capture the connection URL
        for _ in range(20):
            line = proc.stdout.readline()
            if not line:
                break
            print(line, end="")
            if "http" in line.lower() or "connect" in line.lower():
                break
    else:
        # Foreground — exec into it
        os.execvp("sudo", remote_cmd)


# ── Chrome command ──────────────────────────────────────────────────────────

CHROME_APP = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_AGENT_DIR = "/tmp/chrome-agent"
CHROME_PID_FILE = Path("/tmp/isolator-chrome-agent.pid")
CHROME_DEBUG_PORT = 9222


def cmd_chrome(args):
    """Start or stop a dedicated agent Chrome (empty profile, debug port)."""
    # Parse --port
    port = CHROME_DEBUG_PORT
    if "--port" in args:
        idx = args.index("--port")
        port = int(args[idx + 1])
        args = args[:idx] + args[idx + 2:]

    if "--stop" in args:
        if not CHROME_PID_FILE.exists():
            print("No agent Chrome running")
            return
        pid = int(CHROME_PID_FILE.read_text().strip())
        subprocess.run(["kill", str(pid)], capture_output=True)
        CHROME_PID_FILE.unlink(missing_ok=True)
        print(f"Stopped agent Chrome (pid {pid})")
        return

    # Check if already running
    r = subprocess.run(["curl", "-s", f"http://127.0.0.1:{port}/json/version"],
                       capture_output=True, text=True)
    if r.returncode == 0 and "Chrome" in r.stdout:
        print(f"Agent Chrome already running on port {port}")
        return

    proc = subprocess.Popen(
        [CHROME_APP,
         f"--user-data-dir={CHROME_AGENT_DIR}",
         f"--remote-debugging-port={port}",
         "--no-first-run"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    CHROME_PID_FILE.write_text(str(proc.pid))
    print(f"Started agent Chrome (pid {proc.pid}, port {port})")
    print(f"  Empty profile: {CHROME_AGENT_DIR}")
    print(f"  DevTools: http://127.0.0.1:{port}")


# ── List command ────────────────────────────────────────────────────────────

def cmd_list(config):
    users = config.get("users", {})
    if not users:
        print("No users configured")
        return
    for name, uc in users.items():
        uid = uc.get("uid", "?")
        exists = "exists" if user_exists(name) else "not created"
        hosts = ", ".join(uc.get("hosts", []))
        print(f"  {name:15s} uid={uid:4}  {exists:12s}  hosts: {hosts or '(none)'}")


# ── Main ────────────────────────────────────────────────────────────────────

SUBCOMMANDS = {"create", "delete", "pf", "list", "chrome"}


def parse_create_args(args):
    """Parse options for create subcommand."""
    from_user = None
    names = []

    while args:
        arg = args.pop(0)
        if arg == "--from":
            from_user = args.pop(0)
        elif arg == "--all":
            names.append("--all")
        else:
            names.append(arg)

    return names, from_user


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    # Handle -s flag (SSH mode)
    use_ssh = False
    argv = sys.argv[1:]
    if argv and argv[0] == "-s":
        use_ssh = True
        argv = argv[1:]

    if not argv:
        print(__doc__)
        sys.exit(0)

    subcmd = argv[0]

    # ── iso [-s] <user> [command] [args...] ──
    if subcmd not in SUBCOMMANDS and not subcmd.startswith("-"):
        subcmd = validate_username(subcmd)
        cmd = argv[1] if len(argv) >= 2 else "bash"
        if cmd == "remote":
            cmd_remote(subcmd, argv[2:])
            return
        cmd_run(subcmd, cmd, argv[2:], use_ssh=use_ssh)
        return

    # Everything below requires root (except list and chrome)
    if subcmd not in ("list", "chrome") and os.geteuid() != 0:
        # Re-exec with sudo
        os.execvp("sudo", ["sudo"] + sys.argv)

    config = load_config()

    if subcmd == "create":
        names, from_user = parse_create_args(argv[1:])
        if not names:
            print("Usage: iso create <name> [options]")
            sys.exit(1)
        if "--all" in names:
            for name in config.get("users", {}):
                cmd_create(name, config, from_user)
        else:
            for name in names:
                cmd_create(name, config, from_user)

    elif subcmd == "delete":
        if len(argv) < 2:
            print("Usage: iso delete <name>")
            sys.exit(1)
        if argv[1] == "--all":
            for name in config.get("users", {}):
                cmd_delete(name)
        else:
            cmd_delete(argv[1])

    elif subcmd == "pf":
        dry_run = "--dry-run" in argv
        cmd_pf(config, dry_run)

    elif subcmd == "chrome":
        cmd_chrome(argv[1:])

    elif subcmd == "list":
        cmd_list(config)


if __name__ == "__main__":
    main()
