#!/usr/bin/env python3
"""iso: Unified command for macOS user isolation for AI coding agents.

Usage:
    iso create <name> [options]       Create an isolated user
    iso create --all [options]        Create all users from config
    iso delete <name>                 Delete an isolated user and its home
    iso delete --all                  Delete all users from config
    iso install                       Deploy /etc/isolator files + sshd drop-in (one-time setup)
    iso install --dry-run             Print planned file installs without changing anything
    iso copy <claude|codex> <user>    Copy admin's claude/codex config to <user> (overwrites)
                                      [--from <src-user>] (default: admin)
    iso pf                            Apply firewall rules from config (run after host edits)
    iso pf --dry-run                  Print firewall rules without loading
    iso list                          List configured users
    iso <user> [command] [args...]     Run command as isolated user (default: bash)
    iso -s <user> [command] [args...] Run via SSH (proper login session, no GUI)
    iso <user> remote [--bg]          Start sandboxed remote session for Claude Desktop
    iso <user> remote --status        Show remote session status
    iso <user> remote --stop          Stop remote session
    iso <user> acm [args...]          Launch sandboxed acm-shell session as <user>
    iso chrome [--port PORT]          Start agent Chrome (empty profile, default 9222)
    iso chrome --stop                 Stop agent Chrome

Options for create:
    --from USER                       Copy config from USER (default: admin)
    --refresh-files                   Re-copy shell/claude/codex/ssh files even
                                      if the user already exists (overwrites
                                      any local customizations). Default: skip
                                      file copy on existing users.

Examples:
    iso create acm
    iso acm claude                    # first run: /login to authenticate
    iso chrome                        # start safe browser for agents
    iso acm remote --bg               # connect from Claude Desktop
    iso delete acm
    iso install                       # one-time setup of /etc/isolator + sshd drop-in
    iso pf                            # after editing hosts/users in config.toml
"""

import json
import os
import re
import shlex
import shutil
import socket
import subprocess
import sys
import tomllib
from pathlib import Path

# ── Config ──────────────────────────────────────────────────────────────────

CONFIG_PATH = Path("/etc/isolator/config.toml")
PROFILE_PATH = Path("/etc/isolator/profile")
CLAUDE_MD_PATH = Path("/etc/isolator/CLAUDE.md")
ANCHOR_PATH = Path("/etc/pf.anchors/isolator")
PF_CONF = Path("/etc/pf.conf")
BASE_UID = 600
DOCKER_SUBNET_BASE = "172.30"  # per-user: 172.30.0.0/24, 172.30.1.0/24, ...
ISOLATOR_GROUP = "isolator"  # dedicated group for sandbox users (NOT staff)
NETSHOOT_IMAGE = "nicolaka/netshoot"
SSH_KEY_NAME = "isolator"  # ~/.ssh/isolator (single key for all sandbox users)
SSH_OPTS = ["-o", "StrictHostKeyChecking=no", "-o", "UserKnownHostsFile=/dev/null",
            "-o", "LogLevel=ERROR"]
WORKSPACES_DIR = Path("/Users/Workspaces")
DOCKER_PROXY_DIR = Path("/var/run/isolator-docker")  # root-only system dir
REMOTE_PID_DIR_PATH = Path("/var/run/isolator-remote")  # root-only system dir
DOCKER_PROXY_SCRIPT = Path("/usr/local/bin/docker-proxy-go")

SHELL_RC_FILES = {
    "bash": [".bash_profile", ".bashrc"],
    "zsh": [".zprofile", ".zshrc"],
}

SHARED_TOOLS = [
    {
        "name": "codex",
        "bin": Path("/opt/homebrew/bin/codex"),
        "package_dir": Path("/opt/homebrew/lib/node_modules/@openai/codex"),
    },
]

KEYCHAIN_NAME = "login.keychain-db"

# Extra flags injected when running these commands via `iso <user> <cmd>`
COMMAND_FLAGS = {
    "claude": ["--permission-mode", "bypassPermissions"],
}

# ── Helpers ─────────────────────────────────────────────────────────────────

def run(cmd, check=True):
    """Run a shell command. Show output on failure for easier debugging."""
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        if check or os.environ.get("ISOLATOR_DEBUG"):
            print(f"  {'ERROR' if check else 'WARN'}: {' '.join(cmd)}")
            if r.stdout.strip():
                print(f"         stdout: {r.stdout.strip()}")
            if r.stderr.strip():
                print(f"         stderr: {r.stderr.strip()}")
        if check:
            r.check_returncode()
    return r


def run_as(user, cmd, check=True):
    """Run a command as another user via uid/gid switch."""
    import pwd
    pw = pwd.getpwnam(user)
    home = pw.pw_dir

    def switch_user():
        os.setgid(pw.pw_gid)
        os.setuid(pw.pw_uid)
        os.environ["HOME"] = home

    r = subprocess.run(cmd, capture_output=True, text=True, preexec_fn=switch_user)
    if check and r.returncode != 0:
        print(f"  ERROR (as {user}): {' '.join(cmd)}")
        if r.stderr:
            print(f"         {r.stderr.strip()}")
        r.check_returncode()
    return r


def load_config():
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def get_admin():
    """Get admin username from config (fallback: $USER)."""
    try:
        with open(CONFIG_PATH, "rb") as f:
            return tomllib.load(f).get("admin") or os.environ.get("USER", "")
    except (OSError, tomllib.TOMLDecodeError, PermissionError):
        return os.environ.get("USER", "")


def dscl_read(user, key):
    r = run(["dscl", ".", "-read", f"/Users/{user}", key], check=False)
    if r.returncode != 0:
        return None
    for line in r.stdout.strip().splitlines():
        if line.startswith(f"{key}:"):
            return line.split(":", 1)[1].strip()
    return None


def user_exists(name):
    r = run(["dscl", ".", "-read", f"/Users/{name}"], check=False)
    return r.returncode == 0


def detect_shell(user):
    shell = dscl_read(user, "UserShell") or "/bin/zsh"
    if "zsh" in shell:
        return "zsh", shell
    return "bash", shell


VALID_USERNAME_RE = re.compile(r"^[A-Za-z0-9_.-]+$")


def validate_username(name):
    """Reject path-like or otherwise unsafe sandbox user names."""
    if not isinstance(name, str) or not name:
        raise ValueError("invalid sandbox user name: empty")
    if name.startswith("-"):
        raise ValueError(f"invalid sandbox user name {name!r}: cannot start with '-'")
    if "/" in name or "\\" in name or ".." in name or any(ch.isspace() for ch in name):
        raise ValueError(f"invalid sandbox user name {name!r}: must be a simple local account name")
    if not VALID_USERNAME_RE.fullmatch(name):
        raise ValueError(
            f"invalid sandbox user name {name!r}: allowed characters are letters, digits, '_', '.', '-'"
        )
    return name


# ── Create ──────────────────────────────────────────────────────────────────

def next_uid(users):
    used = {u["uid"] for u in users.values() if "uid" in u}
    uid = BASE_UID
    while uid in used:
        uid += 1
    return uid


def add_user_to_config(name, uid):
    entry = f"\n[users.{name}]\nuid = {uid}\n"
    with open(CONFIG_PATH, "a") as f:
        f.write(entry)
    print(f"  Added [users.{name}] (uid={uid}) to {CONFIG_PATH}")


def ensure_isolator_group():
    """Create the isolator group if it doesn't exist (gid 700)."""
    r = run(["dscl", ".", "-read", f"/Groups/{ISOLATOR_GROUP}"], check=False)
    if r.returncode == 0:
        return
    print(f"  Creating group {ISOLATOR_GROUP} (gid=700)")
    run(["dscl", ".", "-create", f"/Groups/{ISOLATOR_GROUP}"])
    run(["dscl", ".", "-create", f"/Groups/{ISOLATOR_GROUP}", "PrimaryGroupID", "700"])


def create_macos_user(name, uid, shell_path):
    home = f"/Users/{name}"
    print(f"  Creating macOS user {name} (uid={uid}, shell={shell_path})")
    ensure_isolator_group()
    run(["dscl", ".", "-create", f"/Users/{name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UserShell", shell_path])
    run(["dscl", ".", "-create", f"/Users/{name}", "RealName", f"Isolator {name}"])
    run(["dscl", ".", "-create", f"/Users/{name}", "UniqueID", str(uid)])
    # Use isolator group (NOT staff) — staff has access to too many things
    run(["dscl", ".", "-create", f"/Users/{name}", "PrimaryGroupID", "700"])
    run(["dscl", ".", "-create", f"/Users/{name}", "NFSHomeDirectory", home])
    run(["dscl", ".", "-create", f"/Users/{name}", "IsHidden", "1"])


def setup_home(name, admin):
    home = Path(f"/Users/{name}")
    print(f"  Setting up home {home}")
    home.mkdir(mode=0o700, exist_ok=True)
    run(["chown", f"{name}:{ISOLATOR_GROUP}", str(home)])
    run(["chmod", "700", str(home)])
    run(["chmod", "+a",
         f"{admin} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(home)])


def write_minimal_shell_config(name, shell_type):
    """Write minimal sandbox shell rc files (no inheritance from admin).

    Sandbox users don't get admin's bash quirks, broken homebrew completions,
    or admin-specific aliases. They get a minimal rc that sources
    /etc/isolator/profile (which sets PATH, DOCKER_HOST, TMPDIR, ISO_TOKEN_*
    unwrap, etc.). Sandbox user can edit these files themselves to add
    customizations — set_ownership leaves them user-writable.
    """
    home = Path(f"/Users/{name}")
    rc_files = SHELL_RC_FILES.get(shell_type, [])
    content = (
        "# Isolator sandbox shell init.\n"
        "# Add your own customizations below the source line.\n"
        f"[[ -f {PROFILE_PATH} ]] && source {PROFILE_PATH}\n"
    )
    for rc in rc_files:
        rc_path = home / rc
        rc_path.write_text(content)
        print(f"  Wrote minimal {rc_path}")


def write_gitconfig(name, user_config):
    """Write ~/.gitconfig with URL-prefix credential routing.

    Maps from `[users.<name>.git_credentials]` config:
        "https://github.com/Altinity"      = "ALTINITY_GITHUB_TOKEN"
        "https://github.com/BorisTyshkevich" = "PERSONAL_GITHUB_TOKEN"

    For each entry, emits a `[credential "<url>"]` block whose helper
    reads the named env var at git-invocation time. Token values come
    from `[users.<name>.auth]` via 1Password and are delivered in-RAM
    to the sandbox shell. URLs not matching any prefix fall through to
    anonymous HTTPS — fine for public repos.

    `useHttpPath = true` is required so git matches the section name
    against the full URL including path (otherwise only host matches).
    """
    creds = user_config.get("git_credentials", {})
    if not creds:
        return

    home = Path(f"/Users/{name}")
    gc = home / ".gitconfig"
    if gc.exists():
        print(f"  Skipping {gc} (already exists; edit by hand to reroute)")
        return

    lines = [
        "# Isolator sandbox gitconfig.",
        "# Routes HTTPS clone credentials by repo owner so each PAT only",
        "# touches its scoped repos. Public repos work without a token.",
        "# Add user.name / user.email and other personal config below.",
        "",
        "[credential]",
        "    useHttpPath = true",
        "",
    ]
    for url_prefix, var_name in creds.items():
        # Helper: only emit creds for `get` (not store/erase). Reads env var
        # at exec time so rotated tokens take effect on next session. The
        # value is a git-config double-quoted string; inner `"` and `\` must
        # be backslash-escaped.
        helper_cmd = (
            f'!f() {{ test \\"$1\\" = get && '
            f'{{ echo username=git; echo \\"password=${var_name}\\"; }}; }}; f'
        )
        lines.append(f'[credential "{url_prefix}"]')
        lines.append(f'    helper = "{helper_cmd}"')
        lines.append("")

    gc.write_text("\n".join(lines) + "\n")
    print(f"  Wrote {gc} ({len(creds)} credential routes)")


def install_sandbox_claude_md(name):
    """Install /etc/isolator/CLAUDE.md as ~/.claude/CLAUDE.md (locked).

    Sandbox policy doc — tells the agent it's running in a sandbox
    (workspace path, /tmp restrictions, Chrome rules, network allowlist).
    Always overwritten so updates to /etc/isolator/CLAUDE.md propagate
    on next `iso create <user>`. Doesn't merge with the admin's
    personal CLAUDE.md — sandbox policy is policy, not preference.

    Made root-owned mode 0444 by set_ownership so sandbox agents can't
    rewrite their own sandbox instructions.
    """
    if not CLAUDE_MD_PATH.exists():
        print(f"  WARNING: {CLAUDE_MD_PATH} missing — run `iso install` first")
        return
    home = Path(f"/Users/{name}")
    claude_dir = home / ".claude"
    claude_dir.mkdir(exist_ok=True)
    dst = claude_dir / "CLAUDE.md"
    shutil.copyfile(CLAUDE_MD_PATH, dst)
    print(f"  Installed sandbox CLAUDE.md -> {dst}")


def ensure_shared_tool_access():
    for tool in SHARED_TOOLS:
        bin_path = tool["bin"]
        package_dir = tool["package_dir"]
        if not bin_path.exists():
            continue
        if not package_dir.exists():
            print(f"  WARNING: {tool['name']} binary exists but package dir {package_dir} is missing")
            continue
        print(f"  Ensuring shared access to {tool['name']} in {package_dir}")
        run(["chmod", "-R", "a+rX", str(package_dir)])
        if bin_path.is_symlink():
            run(["chmod", "-h", "755", str(bin_path)], check=False)


# ── Auth ────────────────────────────────────────────────────────────────────
# Claude Code auth: user runs /login on first use → stores in macOS keychain
# with ACL that only allows Claude Code to read. No credentials copied by iso.
#
# Other env vars (OPENAI_API_KEY, etc.): injected from config key files → .env

def create_empty_keychain(name):
    """Create an empty default keychain so Claude Code can store credentials.

    Uses a fixed password ("isolator") since the keychain is protected by
    filesystem permissions (chmod 700 on home). The password isn't a
    security boundary — the keychain entry ACLs are.
    """
    home = Path(f"/Users/{name}")
    kc_dir = home / "Library" / "Keychains"
    kc_file = kc_dir / KEYCHAIN_NAME

    if kc_file.exists():
        return  # already exists

    kc_dir.mkdir(parents=True, exist_ok=True)
    run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(home / "Library")])
    run_as(name, ["security", "create-keychain", "-p", "isolator", str(kc_file)])
    run_as(name, ["security", "default-keychain", "-s", str(kc_file)])
    run_as(name, ["security", "list-keychains", "-s", str(kc_file)])
    run_as(name, ["security", "set-keychain-settings", str(kc_file)])  # no auto-lock
    run_as(name, ["security", "unlock-keychain", "-p", "isolator", str(kc_file)])
    print(f"  Created empty default keychain")


def resolve_auth_secrets(user_config):
    """Resolve secrets declared in [users.<name>.auth] to a {var: value} dict.

    Values must be 1Password references in the form
    `op://vault/item/field`. Resolved via the `op` CLI at session start;
    returned in-memory. The caller delivers them via process env
    (sudo --preserve-env / ssh SendEnv). No `.env` file is written.

    Empty dict if no auth section. Exits with a clear message on any
    failure (op not installed, op session expired, malformed URI, etc).

    iso typically runs as root (re-exec'd via sudo). The `op` CLI uses the
    admin's app integration / config dir under their home and refuses to
    read it when the effective UID doesn't match. Detect SUDO_USER and
    drop privileges back to that user for the op call.
    """
    auth = user_config.get("auth", {})
    if not auth:
        return {}

    sudo_user = os.environ.get("SUDO_USER")
    if os.geteuid() == 0 and sudo_user:
        op_prefix = ["sudo", "-u", sudo_user]
    else:
        op_prefix = []

    resolved = {}
    for var, value_spec in auth.items():
        if not isinstance(value_spec, str) or not value_spec.startswith("op://"):
            print(f"FATAL: auth value for {var} must be a 1Password URI "
                  f"(op://vault/item/field); got {value_spec!r}",
                  file=sys.stderr)
            sys.exit(1)
        try:
            r = subprocess.run(
                [*op_prefix, "op", "read", "--no-newline", value_spec],
                capture_output=True, text=True, check=False,
            )
        except FileNotFoundError:
            print(f"FATAL: 'op' CLI not found. Install 1Password CLI "
                  f"(brew install --cask 1password-cli) to resolve {var}.",
                  file=sys.stderr)
            sys.exit(1)
        if r.returncode != 0:
            err = r.stderr.strip()
            low = err.lower()
            if "signed in" in low or "session" in low or "signin" in low:
                print(f"FATAL: 1Password session not active. "
                      f"Run: eval $(op signin)", file=sys.stderr)
                print(f"       (then re-run this command)", file=sys.stderr)
            else:
                print(f"FATAL: failed to resolve {var} from {value_spec}: {err}",
                      file=sys.stderr)
            sys.exit(1)
        resolved[var] = r.stdout

    return resolved


# ── Ownership ───────────────────────────────────────────────────────────────

def create_skeleton(name, admin):
    home = Path(f"/Users/{name}")
    for d in [".local/bin", ".local/lib", ".cache", "tmp"]:
        (home / d).mkdir(parents=True, exist_ok=True)
    # Shared workspaces root
    WORKSPACES_DIR.mkdir(mode=0o775, exist_ok=True)
    # /Users/Workspaces is root-only writable; admin uses ACL to read,
    # per-user dirs are created and owned by their respective sandbox users
    run(["chown", "root:wheel", str(WORKSPACES_DIR)], check=False)
    run(["chmod", "755", str(WORKSPACES_DIR)], check=False)
    # Per-user workspace
    user_ws = WORKSPACES_DIR / name
    user_ws.mkdir(exist_ok=True)
    run(["chown", f"{name}:{ISOLATOR_GROUP}", str(user_ws)])
    run(["chmod", "700", str(user_ws)])
    # Sandbox user gets full inheriting ACE on their own workspace so files
    # created there by anyone (e.g. admin bvt) remain writable by the user.
    run(["chmod", "+a",
         f"{name} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(user_ws)])
    run(["chmod", "+a",
         f"{admin} allow read,write,append,delete,delete_child,list,search,readattr,writeattr,readextattr,writeextattr,readsecurity,file_inherit,directory_inherit",
         str(user_ws)])
    print(f"  Workspace: {user_ws}")


def set_ownership(name):
    """Lock down sandbox-policy files; leave user-config files editable.

    iso no longer copies admin's claude/codex configs into sandbox homes —
    Claude Code and Codex create those files themselves on first run, owned
    by the sandbox user. So this function only handles:
      - rc files (we wrote minimal versions)
      - .claude/CLAUDE.md (policy doc — root-owned, locked)
      - .claude/ dir itself (must be user-writable)
      - skeleton dirs (.local, .cache, tmp)
    """
    home = Path(f"/Users/{name}")

    # Sandbox shell rc files: user-editable. Owner can write; isolator
    # group can read; no world access. .gitconfig same treatment — sandbox
    # user can add user.name/user.email; the credential helpers read tokens
    # from env at git-invocation time, no secrets in the file.
    for f in [".bash_profile", ".bashrc", ".zprofile", ".zshrc", ".gitconfig"]:
        path = home / f
        if path.exists():
            run(["chown", f"{name}:{ISOLATOR_GROUP}", str(path)])
            run(["chmod", "640", str(path)])

    # ~/.claude/ exists because we install the sandbox CLAUDE.md there.
    # The directory itself must be user-owned so Claude Code can write
    # session files; the CLAUDE.md inside is locked policy.
    claude_dir = home / ".claude"
    if claude_dir.exists():
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(claude_dir)])
        run(["chmod", "700", str(claude_dir)])
    claude_md = claude_dir / "CLAUDE.md"
    if claude_md.exists():
        run(["chown", "root:wheel", str(claude_md)])
        run(["chmod", "444", str(claude_md)])

    # Skeleton dirs created by create_skeleton — user-owned.
    for d in [".local", ".cache", "tmp"]:
        path = home / d
        if path.exists():
            run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(path)])


def ssh_key_path(admin):
    """Return path to admin's isolator SSH private key."""
    return Path(f"/Users/{admin}/.ssh/{SSH_KEY_NAME}")


def setup_ssh_key(name, admin):
    """Generate admin keypair (once) and install public key for sandbox user."""
    admin_home = Path(f"/Users/{admin}")
    user_home = Path(f"/Users/{name}")

    priv_key = admin_home / ".ssh" / SSH_KEY_NAME

    # Generate keypair if it doesn't exist
    if not priv_key.exists():
        (admin_home / ".ssh").mkdir(mode=0o700, exist_ok=True)
        run(["ssh-keygen", "-t", "ed25519", "-f", str(priv_key),
             "-N", "", "-q", "-C", f"isolator@{subprocess.run(['hostname', '-s'], capture_output=True, text=True).stdout.strip()}"])
        run(["chmod", "600", str(priv_key)])
        run(["chown", f"{admin}:staff", str(priv_key), str(priv_key.with_suffix(".pub"))])
        print(f"  Generated SSH keypair: {priv_key}")

    pub_key = priv_key.with_suffix(".pub").read_text().strip()

    # Install public key in sandbox user's authorized_keys
    user_ssh = user_home / ".ssh"
    user_ssh.mkdir(exist_ok=True)
    auth_keys = user_ssh / "authorized_keys"
    auth_keys.write_text(pub_key + "\n")
    run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(user_ssh)])
    run(["chmod", "700", str(user_ssh)])
    run(["chmod", "600", str(auth_keys)])

    # Add to SSH service ACL group (created by macOS when Remote Login enabled)
    r = run(["dscl", ".", "-read", "/Groups/com.apple.access_ssh"], check=False)
    if r.returncode != 0:
        print(f"  WARNING: SSH ACL group not found — Remote Login may not be enabled")
        print(f"           SSH mode (iso -s) won't work until you enable Remote Login")
    else:
        run(["dscl", ".", "-append", "/Groups/com.apple.access_ssh",
             "GroupMembership", name])
        print(f"  SSH key installed, added to SSH access group")


def exclude_from_backup(name):
    """Exclude user home and keychain password from Time Machine."""
    home = Path(f"/Users/{name}")
    run(["tmutil", "addexclusion", str(home)], check=False)
    print(f"  Excluded from Time Machine backup")


def user_subnet(config, name):
    """Return the Docker subnet for a user based on position in config."""
    users = list(config.get("users", {}).keys())
    idx = users.index(name) if name in users else len(users)
    return f"{DOCKER_SUBNET_BASE}.{idx}.0/24"


def create_docker_network(name, config):
    """Create a per-user Docker network with a dedicated subnet."""
    net_name = f"iso-{name}"
    subnet = user_subnet(config, name)
    # Check if network exists
    r = run(["docker", "network", "inspect", net_name], check=False)
    if r.returncode == 0:
        print(f"  Docker network {net_name} already exists")
        return
    run(["docker", "network", "create", f"--subnet={subnet}", net_name], check=False)
    print(f"  Created Docker network {net_name} ({subnet})")


# ── Create command ──────────────────────────────────────────────────────────

def cmd_create(name, config, from_user=None, refresh_files=False):
    """Create one isolated user.

    For brand-new users: provisions the macOS account and copies all skeleton
    files (shell rc, claude config, codex config, ssh key, etc.) from the
    source user.

    For users that already exist: by default we run only the *idempotent*
    setup steps (group membership, dir perms, ACLs, auth keyfiles, docker
    network, ownership). Skeleton-file copying is SKIPPED so the user's
    local customizations (.bash_profile, .claude/CLAUDE.md, .codex/config.toml,
    ~/.ssh/) are preserved across re-runs of `iso create`.

    Pass --refresh-files to force re-copying everything, useful after the
    admin's source files change and you want sandbox users to inherit the
    update.
    """
    name = validate_username(name)
    users = config.get("users", {})
    admin = config["admin"]

    if name not in users:
        uid = next_uid(users)
        add_user_to_config(name, uid)
        users[name] = {"uid": uid}

    user_config = users[name]
    uid = user_config["uid"]
    source = from_user or user_config.get("from", admin)

    print(f"\n=== Creating {name} (uid={uid}, from={source}) ===")

    admin_home = Path(f"/Users/{admin}")
    if admin_home.stat().st_mode & 0o077:
        print(f"  Locking admin home {admin_home} to 700")
        run(["chmod", "700", str(admin_home)])

    # Ensure isolator group exists (idempotent) — needed even if user exists
    ensure_isolator_group()

    is_new = not user_exists(name)
    if is_new:
        shell_type, shell_path = detect_shell(source)
        create_macos_user(name, uid, shell_path)
    else:
        print(f"  User {name} already exists, skipping dscl creation")

    shell_type, shell_path = detect_shell(source)

    # Shell rc files: written minimally (just sources /etc/isolator/profile)
    # for new users or with --refresh-files. Sandbox user can edit them
    # afterward (set_ownership leaves them user:isolator mode 644).
    do_copy = is_new or refresh_files
    if not do_copy:
        print(f"  Skipping skeleton file rewrite (use --refresh-files to reset)")

    setup_home(name, admin)
    if do_copy:
        write_minimal_shell_config(name, shell_type)
        write_gitconfig(name, user_config)

    # Sandbox CLAUDE.md (policy doc) is always refreshed so updates to
    # /etc/isolator/CLAUDE.md propagate. Locked root:wheel 444 by
    # set_ownership so the agent can't rewrite its own sandbox rules.
    install_sandbox_claude_md(name)

    # Wipe any stale .env left from the old keyfile-injection scheme — secrets
    # are now resolved at session start and delivered in-RAM via process env.
    stale_env = Path(f"/Users/{name}/.env")
    if stale_env.exists():
        print(f"  Removing stale {stale_env} (secrets now in-RAM)")
        stale_env.unlink()
    create_empty_keychain(name)
    create_skeleton(name, admin)
    create_docker_network(name, config)
    if do_copy:
        setup_ssh_key(name, admin)
    ensure_shared_tool_access()
    set_ownership(name)
    exclude_from_backup(name)

    print(f"=== Done: {name} ===")


# ── Delete command ──────────────────────────────────────────────────────────

def cmd_delete(name):
    """Delete one isolated user and its home directory."""
    name = validate_username(name)
    home = Path(f"/Users/{name}")

    print(f"\n=== Deleting {name} ===")

    if user_exists(name):
        kc_file = home / "Library" / "Keychains" / KEYCHAIN_NAME
        if kc_file.exists():
            run(["security", "delete-keychain", str(kc_file)], check=False)
        print(f"  Removing macOS user {name}")
        run(["dscl", ".", "-delete", f"/Users/{name}"])
    else:
        print(f"  User {name} does not exist in directory")

    if home.exists():
        print(f"  Removing {home}")
        shutil.rmtree(home)
    else:
        print(f"  Home {home} does not exist")

    print(f"=== Done: {name} ===")


# ── Firewall command ────────────────────────────────────────────────────────

def resolve_hosts(hosts):
    ips = set()
    for host in hosts:
        try:
            results = socket.getaddrinfo(host, 443, socket.AF_INET, socket.SOCK_STREAM)
            for _, _, _, _, addr in results:
                ips.add(addr[0])
        except socket.gaierror as e:
            print(f"  WARNING: cannot resolve {host}: {e}")
    return sorted(ips)


def is_unrestricted(user_config):
    """Check if user has wildcard hosts (unrestricted network)."""
    return "*" in user_config.get("hosts", [])


def should_log(user_config):
    """Check if user has logging enabled."""
    return user_config.get("log", False)


def generate_anchor(config):
    users = config.get("users", {})
    global_cfg = config.get("global", {})
    global_hosts = global_cfg.get("hosts", [])
    global_subnets = global_cfg.get("subnets", [])
    lines = ["# Generated by isolator", ""]
    restricted_uids = []

    for name, user_config in users.items():
        uid = user_config["uid"]
        if is_unrestricted(user_config):
            print(f"  {name} (uid={uid}): unrestricted network")
            continue
        restricted_uids.append(uid)
        hosts = user_config.get("hosts", []) + global_hosts
        subnets = user_config.get("subnets", []) + global_subnets
        log = should_log(user_config)
        print(f"  Resolving hosts for {name} (uid={uid}){'  [logging]' if log else ''}...")
        for h in hosts:
            print(f"    {h}")
        ips = resolve_hosts(hosts)
        if subnets:
            print(f"    subnets: {', '.join(subnets)}")
        print(f"    -> {len(ips)} IPs + {len(subnets)} subnets")
        entries = sorted(ips) + subnets
        if entries:
            ip_list = ", ".join(entries)
            lines.append(f"table <{name}-allowed> {{ {ip_list} }}")

    lines.append("")

    if not restricted_uids:
        print("No restricted users, skipping pf rules")
        return ""

    uid_list = " ".join(str(u) for u in restricted_uids)
    log_kw = "log " if any(should_log(users[n]) for n in users if users[n]["uid"] in restricted_uids) else ""

    # Loopback: pass everything quickly, no further rule processing on lo0.
    # Equivalent to "set skip on lo0" but expressible inside an anchor (set
    # directives only work in the main ruleset). The "quick" keyword makes
    # this rule terminal — matching packets exit rule processing immediately,
    # so the block rules below never see lo0 traffic. This both fixes the
    # SYN-ACK-drop bug that broke sandbox-user TCP listeners (e.g.
    # embedded-clickhouse) AND simplifies the rule set. Security analysis in
    # docs/loopback-policy.md.
    lines.append("pass quick on lo0 all")
    lines.append("")
    lines.append(f"block {log_kw}out proto tcp from any to any user {{ {uid_list} }}")
    lines.append(f"block {log_kw}out proto udp from any to any user {{ {uid_list} }}")
    lines.append("")

    # DNS port 53 — required by Go's pure-Go resolver (CGO_ENABLED=0 binaries)
    # and any tool that opens UDP/53 directly. macOS's libc resolver bypasses
    # pf via mDNSResponder (Mach IPC, no packets from the calling process), so
    # libc-using tools work without this. But static Go binaries (rustup,
    # `acm`, `kubectl` from some builds) panic without it because their
    # UDP/53 socket gets EAGAIN and Go's stdlib has slice-bounds bugs parsing
    # the dropped response. Tradeoff: this enables DNS-tunnel exfiltration
    # in principle, but sandbox users already have HTTPS-to-allowed-hosts
    # which is a much wider channel.
    lines.append(f"pass out proto udp from any to any port 53 user {{ {uid_list} }}")
    lines.append(f"pass out proto tcp from any to any port 53 user {{ {uid_list} }}")
    lines.append("")

    for name, user_config in users.items():
        uid = user_config["uid"]
        if is_unrestricted(user_config):
            continue
        log_kw = "log " if should_log(user_config) else ""
        extra_ports = user_config.get("extra_ports", [])
        ports = " ".join(str(p) for p in [443] + extra_ports)
        port_spec = ports if len(extra_ports) == 0 else f"{{ {ports} }}"
        # macOS pf: user keyword must come after address/port specifiers
        lines.append(f"pass {log_kw}out proto tcp from any to <{name}-allowed> port {port_spec} user {uid}")

    lines.append("")
    return "\n".join(lines)


def ensure_pf_conf():
    """Add isolator anchor to /etc/pf.conf if missing. fcntl-locked."""
    import fcntl
    # Open for read+write, create if missing, and hold an exclusive lock
    # for the entire read-modify-write sequence
    fd = os.open(PF_CONF, os.O_RDWR | os.O_CREAT, 0o644)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        with os.fdopen(fd, "r+") as f:
            content = f.read()
            if 'anchor "isolator"' not in content:
                print(f"  Adding anchor to {PF_CONF}")
                additions = '\nanchor "isolator"\nload anchor "isolator" from "/etc/pf.anchors/isolator"\n'
                f.write(additions)
    except Exception:
        os.close(fd)
        raise


def generate_docker_iptables(config):
    """Generate iptables rules for Docker container egress filtering."""
    users = config.get("users", {})
    global_hosts = config.get("global", {}).get("hosts", [])
    rules = []

    # Flush DOCKER-USER chain
    # Build into staging chain DOCKER-USER-NEW, then atomic swap.
    # Avoids the brief window where DOCKER-USER is empty and traffic flows free.
    rules.append("iptables -N DOCKER-USER-NEW 2>/dev/null || iptables -F DOCKER-USER-NEW")

    for name, user_config in users.items():
        subnet = user_subnet(config, name)
        log = should_log(user_config)

        if is_unrestricted(user_config):
            if log:
                rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j LOG --log-prefix 'iso-{name}: '")
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j ACCEPT")
            continue

        hosts = user_config.get("hosts", []) + global_hosts
        ips = resolve_hosts(hosts)

        rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -d {subnet} -j ACCEPT")
        for ip in ips:
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -d {ip} -p tcp --dport 443 -j ACCEPT")
        if log:
            rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j LOG --log-prefix 'iso-{name}-drop: '")
        rules.append(f"iptables -A DOCKER-USER-NEW -s {subnet} -j DROP")

    # Block default bridge — sandboxed agents must use iso-<user>
    rules.append("iptables -A DOCKER-USER-NEW -s 172.17.0.0/16 -j DROP")
    # Default: allow other Docker traffic (admin's containers)
    rules.append("iptables -A DOCKER-USER-NEW -j ACCEPT")

    # Atomic swap: rename old → backup, new → DOCKER-USER, drop backup
    rules.append("iptables -E DOCKER-USER DOCKER-USER-OLD 2>/dev/null || true")
    rules.append("iptables -E DOCKER-USER-NEW DOCKER-USER")
    rules.append("iptables -F DOCKER-USER-OLD 2>/dev/null || true")
    rules.append("iptables -X DOCKER-USER-OLD 2>/dev/null || true")
    return rules


def apply_docker_iptables(rules, dry_run=False):
    """Apply iptables rules inside the Docker VM via nsenter."""
    script = " && ".join(rules)

    if dry_run:
        print("\n--- Docker iptables rules (dry run) ---")
        for r in rules:
            print(f"  {r}")
        return

    print("\n  Applying Docker iptables rules...")
    # Ensure netshoot image is available
    run(["docker", "pull", "-q", NETSHOOT_IMAGE], check=False)
    r = subprocess.run(
        ["docker", "run", "--rm", "--privileged", "--pid=host", "--network=host",
         NETSHOOT_IMAGE, "sh", "-c", f"nsenter -t 1 -n sh -c '{script}'"],
        capture_output=True, text=True)
    if r.returncode != 0:
        print(f"  WARNING: Docker iptables failed: {r.stderr.strip()}")
    else:
        print("  Docker iptables rules loaded")


def install_etc_files(dry_run=False):
    """Deploy repo etc/ files to system locations (idempotent).

    Files copied:
      etc/profile             -> /etc/isolator/profile          (mode 644)
      etc/CLAUDE.md           -> /etc/isolator/CLAUDE.md        (mode 644)
      etc/open-browser        -> /etc/isolator/open-browser     (mode 755)
      etc/sshd-isolator.conf  -> /etc/ssh/sshd_config.d/isolator.conf (mode 644)

    /etc/isolator/config.toml is NOT touched (operator's source of truth).

    sshd is reloaded only when its drop-in actually changes content.
    """
    repo_etc = Path(__file__).resolve().parent.parent / "etc"
    if not repo_etc.is_dir():
        print(f"  WARNING: repo etc/ not found at {repo_etc}; skipping etc install")
        return

    isolator_etc = Path("/etc/isolator")
    if not isolator_etc.exists():
        if dry_run:
            print(f"  [dry-run] would mkdir {isolator_etc}")
        else:
            isolator_etc.mkdir(parents=True, exist_ok=True)
            run(["chmod", "755", str(isolator_etc)], check=False)
            run(["chown", "root:wheel", str(isolator_etc)], check=False)

    isolator_files = [
        ("profile", 0o644),
        ("CLAUDE.md", 0o644),
        ("open-browser", 0o755),
        ("acm-bootstrap.bash", 0o644),
    ]
    for name, mode in isolator_files:
        src = repo_etc / name
        dst = isolator_etc / name
        if not src.exists():
            continue
        if dst.exists() and dst.read_bytes() == src.read_bytes():
            continue
        if dry_run:
            print(f"  [dry-run] would install {dst}")
            continue
        shutil.copyfile(src, dst)
        os.chmod(dst, mode)
        run(["chown", "root:wheel", str(dst)], check=False)
        print(f"  Installed {dst}")

    # sshd drop-in: only reload sshd when content actually changes.
    sshd_src = repo_etc / "sshd-isolator.conf"
    sshd_dst = Path("/etc/ssh/sshd_config.d/isolator.conf")
    sshd_changed = False
    if sshd_src.exists():
        existing = sshd_dst.read_bytes() if sshd_dst.exists() else b""
        if existing != sshd_src.read_bytes():
            if dry_run:
                print(f"  [dry-run] would install {sshd_dst} and reload sshd")
            else:
                sshd_dst.parent.mkdir(parents=True, exist_ok=True)
                shutil.copyfile(sshd_src, sshd_dst)
                os.chmod(sshd_dst, 0o644)
                run(["chown", "root:wheel", str(sshd_dst)], check=False)
                print(f"  Installed {sshd_dst}")
                sshd_changed = True

    if sshd_changed:
        print("  Reloading sshd (kickstart com.openssh.sshd)...")
        r = subprocess.run(
            ["launchctl", "kickstart", "-k", "system/com.openssh.sshd"],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            print(f"  WARNING: sshd reload failed: {r.stderr.strip()}")


def cmd_install(dry_run=False):
    """Deploy /etc/isolator system files + sshd drop-in (one-time setup).

    Idempotent: re-running just refreshes whatever changed in the repo.
    sshd is reloaded only when the drop-in's content actually changes.
    Does NOT touch firewall rules — see `iso pf` for that.

    Files synced:
      etc/profile             -> /etc/isolator/profile
      etc/CLAUDE.md           -> /etc/isolator/CLAUDE.md
      etc/open-browser        -> /etc/isolator/open-browser
      etc/sshd-isolator.conf  -> /etc/ssh/sshd_config.d/isolator.conf
    """
    install_etc_files(dry_run=dry_run)


def cmd_pf(config, dry_run=False):
    """Generate and apply macOS pf rules + Docker iptables rules.

    Run after editing config.toml (host changes, new users, etc.).
    Pure firewall — does not touch files in /etc/isolator. See
    `iso install` for that one-time setup.
    """
    anchor = generate_anchor(config)
    if not anchor:
        return
    if dry_run:
        print("\n--- Generated pf anchor (dry run) ---")
        print(anchor)
    else:
        print(f"\n  Writing {ANCHOR_PATH}")
        ANCHOR_PATH.parent.mkdir(parents=True, exist_ok=True)
        ANCHOR_PATH.write_text(anchor)
        ensure_pf_conf()
        print("  Loading pf rules...")
        r = subprocess.run(["pfctl", "-ef", str(PF_CONF)],
                           capture_output=True, text=True)
        if r.returncode != 0:
            print(f"  ERROR: pfctl failed: {r.stderr}")
            sys.exit(1)
        print("  pf rules loaded")

    # Docker iptables rules
    docker_rules = generate_docker_iptables(config)
    apply_docker_iptables(docker_rules, dry_run)


# ── Run command ─────────────────────────────────────────────────────────────

def proxy_tcp_port(user_config):
    """Deterministic per-user TCP port for the docker-proxy TLS listener.

    Sandbox UIDs start at 600. Map to ports 40000+: altinity(606) -> 40006.
    Predictable so the user's profile/env can hardcode it without lookup.
    """
    return 40000 + (user_config["uid"] - BASE_UID)


def ensure_proxy_tls_certs(user):
    """Generate the TLS cert tree for the docker-proxy TCP listener if missing.

    Cert tree lives at /Users/<user>/.isolator-docker-proxy/, owned by the
    user (mode 0700). testcontainers reads DOCKER_CERT_PATH from this dir.

    Returns the cert dir path (Path).
    """
    cert_dir = Path(f"/Users/{user}/.isolator-docker-proxy")
    ca_file = cert_dir / "ca.pem"

    if ca_file.exists():
        return cert_dir

    # mkdir + chown to user, then run --init-tls as root (writes files)
    subprocess.run(["sudo", "mkdir", "-p", str(cert_dir)], capture_output=True)
    subprocess.run(["sudo", "chown", f"{user}:isolator", str(cert_dir)],
                   capture_output=True)
    subprocess.run(["sudo", "chmod", "0700", str(cert_dir)], capture_output=True)
    r = subprocess.run([
        "sudo", str(DOCKER_PROXY_SCRIPT),
        "--user", user,
        "--tls-cert-dir", str(cert_dir),
        "--init-tls",
    ], capture_output=True, text=True)
    if r.returncode != 0:
        print(f"  WARNING: TLS cert init failed: {r.stderr.strip()}")
        return None
    # Cert files were written as root; chown them to user.
    subprocess.run(["sudo", "chown", "-R", f"{user}:isolator", str(cert_dir)],
                   capture_output=True)
    return cert_dir


def ensure_docker_proxy(user):
    """Start per-user Docker proxy if not already running."""
    # Create proxy dir as root if needed (only root can write to /var/run)
    if not DOCKER_PROXY_DIR.exists():
        subprocess.run(["sudo", "mkdir", "-p", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
        subprocess.run(["sudo", "chown", "root:wheel", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
        # 711: traverse-only (sandbox users can stat /var/run/isolator-docker/<user>.sock
        # if they know the name, but can't list other users' sockets)
        subprocess.run(["sudo", "chmod", "711", str(DOCKER_PROXY_DIR)],
                       capture_output=True)
    else:
        # Verify ownership — refuse to use a hijacked dir
        st = DOCKER_PROXY_DIR.stat()
        if st.st_uid != 0:
            print(f"FATAL: {DOCKER_PROXY_DIR} not root-owned (uid={st.st_uid})")
            sys.exit(1)

    sock = DOCKER_PROXY_DIR / f"{user}.sock"
    pid_file = DOCKER_PROXY_DIR / f"{user}.pid"
    log_file = DOCKER_PROXY_DIR / f"{user}.log"

    # Check if already running (verify pid belongs to docker-proxy)
    if pid_file.exists():
        try:
            # PID file is root-owned (created via sudo tee), read via sudo
            r = subprocess.run(["sudo", "cat", str(pid_file)],
                               capture_output=True, text=True)
            pid = int(r.stdout.strip())
            r = subprocess.run(["ps", "-p", str(pid), "-o", "command="],
                               capture_output=True, text=True)
            if "docker-proxy" in r.stdout and sock.exists():
                return "ready"
        except (ValueError, OSError):
            pass
        subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
        subprocess.run(["sudo", "rm", "-f", str(sock)], capture_output=True)

    # Find upstream Docker socket — use OrbStack socket directly,
    # NOT /var/run/docker.sock (which would be accessible to sandbox users)
    admin = get_admin()
    upstream = Path(f"/Users/{admin}/.orbstack/run/docker.sock")
    if not upstream.exists():
        return "unavailable"  # no Docker / no OrbStack

    # Set up TLS cert tree + compute TCP port for the in-container listener.
    # Used by tools (e.g. testcontainers' Ryuk) that need to reach the proxy
    # from inside a container — bind-mounting a host Unix socket into a VM
    # container doesn't work on macOS (the file is visible but connect() is
    # refused), so we expose a TLS-protected loopback port instead.
    config = load_config()
    user_cfg = config.get("users", {}).get(user)
    cert_dir = None
    tcp_port = None
    if user_cfg and "uid" in user_cfg:
        tcp_port = proxy_tcp_port(user_cfg)
        cert_dir = ensure_proxy_tls_certs(user)

    # Start the proxy in a single sudo invocation so the password prompt and
    # the privileged launch share the same tty/ticket context.
    proxy_argv = [
        shlex.quote(str(DOCKER_PROXY_SCRIPT)),
        "--user", shlex.quote(user),
        "--socket", shlex.quote(str(sock)),
        "--upstream", shlex.quote(str(upstream)),
    ]
    if tcp_port and cert_dir:
        proxy_argv += [
            "--tcp-port", str(tcp_port),
            "--tls-cert-dir", shlex.quote(str(cert_dir)),
        ]
    proxy_cmd = " ".join(proxy_argv)
    subprocess.run(["sudo", "rm", "-f", str(log_file)], capture_output=True)
    redirect = f" >>{shlex.quote(str(log_file))} 2>&1"
    launch_cmd = (
        f"rm -f {shlex.quote(str(sock))} {shlex.quote(str(pid_file))}; "
        f"nohup {proxy_cmd}{redirect} & echo $! > {shlex.quote(str(pid_file))}"
    )
    r = subprocess.run(["sudo", "sh", "-c", launch_cmd], capture_output=True, text=True)
    if r.returncode != 0:
        print("  WARNING: docker-proxy launch failed")
        if r.stderr.strip():
            print(f"           {r.stderr.strip()}")
        return "failed"

    def read_proxy_log():
        r = subprocess.run(["sudo", "cat", str(log_file)], capture_output=True, text=True)
        if r.returncode != 0:
            return ""
        return r.stdout.strip()

    # Wait briefly for the socket to appear, but fail fast if the process dies.
    import time
    for _ in range(10):  # up to 1 second
        if sock.exists():
            return "ready"
        try:
            r = subprocess.run(["sudo", "cat", str(pid_file)], capture_output=True, text=True)
            pid = int(r.stdout.strip())
            r = subprocess.run(["ps", "-p", str(pid), "-o", "command="],
                               capture_output=True, text=True)
            if "docker-proxy" not in r.stdout:
                break
        except (ValueError, OSError):
            break
        time.sleep(0.1)

    log_output = read_proxy_log()
    subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
    subprocess.run(["sudo", "rm", "-f", str(sock)], capture_output=True)
    if log_output:
        print("  docker-proxy output:")
        for line in log_output.splitlines()[-10:]:
            print(f"    {line}")
    return "failed"


def build_ssh_cmd(user, command, extra, args, cwd=None, send_env_vars=None):
    """Build SSH command to run as sandboxed user.

    -A enables agent forwarding so admin's `op ssh agent` (or any other
    SSH agent) provides keys for outbound ssh/git inside the sandbox
    without copying private keys.

    send_env_vars: iterable of env-var names to forward via SendEnv.
    The names should already be ISO_TOKEN_-prefixed; /etc/isolator/profile
    un-prefixes them at session start. Requires sshd to AcceptEnv
    ISO_TOKEN_* (see etc/sshd-isolator.conf).

    The remote command sources /etc/isolator/profile before exec'ing the
    user's command — sshd runs `<shell> -c '...'`, a non-login non-
    interactive shell that wouldn't otherwise read any rc file. Without
    this the ISO_TOKEN_ un-prefix loop never runs and the secrets stay
    invisible to the user's command.
    """
    admin = get_admin()
    priv_key = ssh_key_path(admin)

    # Source the isolator profile (PATH, DOCKER_HOST, ISO_TOKEN_ unwrap,
    # etc.) — sshd's `bash -c <cmd>` doesn't pick up any rc otherwise.
    parts = [". /etc/isolator/profile 2>/dev/null || true"]
    if cwd:
        parts.append(f"cd {shlex.quote(cwd)}")
    quoted = " ".join(shlex.quote(a) for a in [command] + extra + args)
    parts.append(f"exec {quoted}")

    remote = " && ".join(parts)
    cmd = ["ssh", "-A", "-t", "-i", str(priv_key)] + SSH_OPTS
    for var_name in (send_env_vars or []):
        cmd += ["-o", f"SendEnv={var_name}"]
    cmd += [f"{user}@127.0.0.1", remote]
    return cmd


def cmd_run(user, command, args, use_ssh=False, preserve_env=None):
    """Run a command as an isolated user. Default: sudo. With -s: SSH.

    Auth secrets declared in [users.<name>.auth] are resolved here (via
    1Password CLI for op:// URIs) and delivered to the sandboxed process
    via the host transport's env mechanism — never written to disk.

    preserve_env: list of env-var names from the admin shell to pass through
    to the sandbox (sudo path only). Mirrors sudo's own --preserve-env;
    used by wrappers like iso-acm-launcher to forward session-specific
    state (KUBECONFIG_DATA, KUBE_CONTEXT, etc.) without storing on disk.
    Vars not present in os.environ are silently skipped.
    """
    user = validate_username(user)
    docker_status = ensure_docker_proxy(user)
    extra = COMMAND_FLAGS.get(command, [])
    user_ws = WORKSPACES_DIR / user
    cwd = str(user_ws) if user_ws.exists() else None

    # Resolve auth secrets in-memory (calls `op read` per URI; may biometric-prompt).
    config = load_config()
    user_config = config.get("users", {}).get(user, {})
    resolved = resolve_auth_secrets(user_config)

    # Admin-shell env passthrough (e.g., from iso-acm-launcher).
    passthrough = {v: os.environ[v] for v in (preserve_env or []) if v in os.environ}

    if docker_status == "failed":
        print(f"WARNING: Docker proxy for {user} failed to start.")
        print(f"         expected socket: {DOCKER_PROXY_DIR / f'{user}.sock'}")
        print("         shell will start without DOCKER_HOST; fix sudo/OrbStack and retry.")

    if use_ssh:
        admin = get_admin()
        priv_key = ssh_key_path(admin)
        if not priv_key.exists():
            print("SSH key not found. Run 'iso create' first or use sudo mode (without -s).")
            sys.exit(1)
        # Forward each secret as ISO_TOKEN_<name>; remote profile un-prefixes.
        ssh_env = {f"ISO_TOKEN_{k}": v for k, v in resolved.items()}
        ssh_cmd = build_ssh_cmd(user, command, extra, args, cwd,
                                send_env_vars=ssh_env.keys())
        env = {**os.environ, **ssh_env}
        os.execvpe("ssh", ssh_cmd, env)
    else:
        # Sudo mode: inherits admin's GUI session (open, Chrome, etc. work).
        # --preserve-env explicitly lists the secret vars so sudo's default
        # env reset doesn't strip them; -i still gives a login shell so the
        # rest of the profile loads normally.
        all_args = [command] + extra + args
        sudo_args = ["sudo"]
        preserve_names = list(resolved) + list(passthrough)
        if preserve_names:
            sudo_args.append(f"--preserve-env={','.join(preserve_names)}")
        sudo_args += ["-u", user, "-i"]
        if cwd:
            quoted = " ".join(shlex.quote(a) for a in all_args)
            shell_cmd = f"cd {shlex.quote(cwd)} && exec {quoted}"
            sudo_args += ["bash", "-c", shell_cmd]
        else:
            sudo_args += all_args
        env = {**os.environ, **resolved, **passthrough}
        # macOS sudo preserves admin's PATH/MANPATH from the parent env
        # despite env_reset (no secure_path in sudoers, PATH not in
        # env_keep). Strip them so the sandbox login shell rebuilds
        # PATH from path_helper + /etc/isolator/profile, instead of
        # inheriting /Users/<admin>/* dirs that no other user can read.
        for v in ("PATH", "MANPATH"):
            env.pop(v, None)
        os.execvpe("sudo", sudo_args, env)


# ── Remote command ──────────────────────────────────────────────────────────

REMOTE_PID_DIR = REMOTE_PID_DIR_PATH


def remote_pid_file(user):
    user = validate_username(user)
    return REMOTE_PID_DIR / f"{user}.pid"


def cmd_remote(user, args):
    """Manage a sandboxed remote Claude session for Claude Desktop."""
    user = validate_username(user)
    if "--stop" in args:
        pid_file = remote_pid_file(user)
        if not pid_file.exists():
            print(f"No remote session for {user}")
            return
        r = subprocess.run(["sudo", "cat", str(pid_file)],
                           capture_output=True, text=True)
        try:
            pid = int(r.stdout.strip())
        except ValueError:
            print(f"Invalid pid file for {user}")
            return
        # Verify the PID belongs to our user (prevent killing arbitrary process)
        r = subprocess.run(["ps", "-p", str(pid), "-o", "user=,command="],
                           capture_output=True, text=True)
        if user not in r.stdout or "claude" not in r.stdout:
            print(f"PID {pid} doesn't look like a session for {user}, refusing to kill")
            subprocess.run(["sudo", "rm", str(pid_file)], capture_output=True)
            return
        subprocess.run(["sudo", "kill", str(pid)], capture_output=True)
        subprocess.run(["sudo", "rm", str(pid_file)], capture_output=True)
        print(f"Stopped remote session for {user} (pid {pid})")
        return

    if "--status" in args:
        pid_file = remote_pid_file(user)
        if not pid_file.exists():
            print(f"No remote session for {user}")
            return
        # PID file is root-owned (dir is 700)
        r = subprocess.run(["sudo", "cat", str(pid_file)],
                           capture_output=True, text=True)
        try:
            pid = int(r.stdout.strip())
        except ValueError:
            print(f"Invalid pid file for {user}")
            return
        r = subprocess.run(["ps", "-p", str(pid)], capture_output=True)
        if r.returncode == 0:
            print(f"Remote session for {user}: running (pid {pid})")
        else:
            print(f"Remote session for {user}: not running (stale pid file)")
            subprocess.run(["sudo", "rm", "-f", str(pid_file)], capture_output=True)
        return

    bg = "--bg" in args

    admin = get_admin()
    priv_key = ssh_key_path(admin)

    # Resolve auth secrets in-memory; deliver via env (no .env on disk).
    config = load_config()
    user_config = config.get("users", {}).get(user, {})
    resolved = resolve_auth_secrets(user_config)

    if priv_key.exists():
        user_ws = WORKSPACES_DIR / user
        cwd = str(user_ws) if user_ws.exists() else None
        ssh_env = {f"ISO_TOKEN_{k}": v for k, v in resolved.items()}
        remote_cmd = build_ssh_cmd(
            user, "claude",
            ["--remote", "--permission-mode", "bypassPermissions"], [],
            cwd, send_env_vars=ssh_env.keys(),
        )
        env_for_remote = {**os.environ, **ssh_env}
    else:
        sudo_args = ["sudo"]
        if resolved:
            sudo_args.append(f"--preserve-env={','.join(resolved)}")
        sudo_args += ["-u", user, "-i",
                      "claude", "--remote", "--permission-mode", "bypassPermissions"]
        remote_cmd = sudo_args
        env_for_remote = {**os.environ, **resolved}

    if bg:
        if not REMOTE_PID_DIR.exists():
            subprocess.run(["sudo", "mkdir", "-p", str(REMOTE_PID_DIR)],
                           capture_output=True)
            subprocess.run(["sudo", "chown", "root:wheel", str(REMOTE_PID_DIR)],
                           capture_output=True)
            subprocess.run(["sudo", "chmod", "700", str(REMOTE_PID_DIR)],
                           capture_output=True)
        else:
            # Refuse hijacked dir
            st = REMOTE_PID_DIR.stat()
            if st.st_uid != 0:
                print(f"FATAL: {REMOTE_PID_DIR} not root-owned (uid={st.st_uid})")
                sys.exit(1)
        proc = subprocess.Popen(
            remote_cmd, env=env_for_remote,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        pid_file = remote_pid_file(user)
        # Write via sudo since dir is root-owned
        subprocess.run(["sudo", "tee", str(pid_file)],
                       input=str(proc.pid), text=True, capture_output=True)
        print(f"Started remote session for {user} in background (pid {proc.pid})")
        # Print first few lines to capture the connection URL
        for _ in range(20):
            line = proc.stdout.readline()
            if not line:
                break
            print(line, end="")
            if "http" in line.lower() or "connect" in line.lower():
                break
    else:
        # Foreground — exec into it
        os.execvpe(remote_cmd[0], remote_cmd, env_for_remote)


# ── Chrome command ──────────────────────────────────────────────────────────

CHROME_APP = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_AGENT_DIR = "/tmp/chrome-agent"
CHROME_PID_FILE = Path("/tmp/isolator-chrome-agent.pid")
CHROME_DEBUG_PORT = 9222


def cmd_chrome(args):
    """Start or stop a dedicated agent Chrome (empty profile, debug port)."""
    # Parse --port
    port = CHROME_DEBUG_PORT
    if "--port" in args:
        idx = args.index("--port")
        port = int(args[idx + 1])
        args = args[:idx] + args[idx + 2:]

    if "--stop" in args:
        if not CHROME_PID_FILE.exists():
            print("No agent Chrome running")
            return
        pid = int(CHROME_PID_FILE.read_text().strip())
        subprocess.run(["kill", str(pid)], capture_output=True)
        CHROME_PID_FILE.unlink(missing_ok=True)
        print(f"Stopped agent Chrome (pid {pid})")
        return

    # Check if already running
    r = subprocess.run(["curl", "-s", f"http://127.0.0.1:{port}/json/version"],
                       capture_output=True, text=True)
    if r.returncode == 0 and "Chrome" in r.stdout:
        print(f"Agent Chrome already running on port {port}")
        return

    proc = subprocess.Popen(
        [CHROME_APP,
         f"--user-data-dir={CHROME_AGENT_DIR}",
         f"--remote-debugging-port={port}",
         "--no-first-run"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    CHROME_PID_FILE.write_text(str(proc.pid))
    print(f"Started agent Chrome (pid {proc.pid}, port {port})")
    print(f"  Empty profile: {CHROME_AGENT_DIR}")
    print(f"  DevTools: http://127.0.0.1:{port}")


# ── Copy command ────────────────────────────────────────────────────────────
#
# `iso copy <claude|codex> <user> [--from <src>]` selectively copies
# admin's claude/codex config into a sandbox user's home. Always
# overwrites. Deliberately does NOT copy:
#   - auth (Claude: per-user macOS Keychain; Codex: auth.json — sandbox
#     user runs `claude /login` / `codex auth login` themselves)
#   - chat history / sessions / logs
#   - admin's plugins or skills (left as empty dirs; future copy mode
#     may handle these with path-rewrite)

CODEX_CONFIG_OVERRIDES = {
    "approval_policy": "never",
    "sandbox_mode": "danger-full-access",
}


def _replace_path(src, dst):
    """Copy file or directory from src to dst, replacing dst if it exists.
    Used for verbatim snapshot copies."""
    if dst.is_symlink() or dst.exists():
        if dst.is_dir() and not dst.is_symlink():
            shutil.rmtree(dst)
        else:
            dst.unlink()
    if src.is_dir():
        shutil.copytree(src, dst)
    else:
        shutil.copy2(src, dst)


def _own_and_perm(path, name, file_mode=0o600, dir_mode=0o700):
    """chown <name>:isolator and chmod path (recursive on dirs)."""
    if path.is_dir():
        run(["chown", "-R", f"{name}:{ISOLATOR_GROUP}", str(path)])
        for p in [path] + list(path.rglob("*")):
            if p.is_symlink():
                continue
            p.chmod(dir_mode if p.is_dir() else file_mode)
    else:
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(path)])
        path.chmod(file_mode)


def _empty_dir(path, name):
    """Replace path with an empty directory, owned by <name>:isolator."""
    if path.is_symlink() or (path.exists() and not path.is_dir()):
        path.unlink()
    elif path.is_dir():
        shutil.rmtree(path)
    path.mkdir()
    _own_and_perm(path, name)


# ── TOML emitter (sanitize Codex config.toml on copy) ──────────────
# Stdlib has no TOML writer; this is a small custom emitter just for
# Codex config — handles scalars, scalar arrays, nested tables, and
# arrays of tables. Brought back from pre-d5913c1 for the copy command.

def _toml_escape(s):
    return s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


# TOML "bare keys" allow only A-Za-z0-9_-. Anything else (dot, slash,
# space, etc.) needs a quoted key, otherwise dots in the key get
# parsed as a dotted-key path on the next read. (Hit this with codex's
# `[tui.model_availability_nux]` table whose scalar keys include
# `gpt-5.5` — without quoting, `gpt-5.5 = 1` is parsed as the table
# `gpt-5` with key `5`, flipping a scalar into a map.)
_TOML_BARE_KEY_RE = re.compile(r"^[A-Za-z0-9_-]+$")


def _toml_key(k):
    if _TOML_BARE_KEY_RE.fullmatch(k):
        return k
    return f'"{_toml_escape(k)}"'


def _toml_emit_value(v):
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int) or isinstance(v, float):
        return str(v)
    if isinstance(v, str):
        return f'"{_toml_escape(v)}"'
    if isinstance(v, list):
        return "[" + ", ".join(_toml_emit_value(x) for x in v) + "]"
    raise TypeError(f"unsupported TOML value type: {type(v).__name__}")


def _toml_emit(data, prefix=""):
    out = []
    scalars = {k: v for k, v in data.items() if not isinstance(v, dict)
               and not (isinstance(v, list) and v and all(isinstance(x, dict) for x in v))}
    for k, v in scalars.items():
        out.append(f"{_toml_key(k)} = {_toml_emit_value(v)}")
    for k, v in data.items():
        if isinstance(v, dict):
            qk = _toml_key(k)
            section = f"{prefix}.{qk}" if prefix else qk
            out.append(f"\n[{section}]")
            out.append(_toml_emit(v, section))
        elif isinstance(v, list) and v and all(isinstance(x, dict) for x in v):
            qk = _toml_key(k)
            section = f"{prefix}.{qk}" if prefix else qk
            for item in v:
                out.append(f"\n[[{section}]]")
                out.append(_toml_emit(item, section))
    return "\n".join(line for line in out if line)


def sanitize_codex_config(src, dst):
    """Parse codex config.toml, drop project trust entries, force bypass mode."""
    try:
        with open(src, "rb") as f:
            data = tomllib.load(f)
    except (OSError, tomllib.TOMLDecodeError) as e:
        print(f"  ERROR parsing {src}: {e}")
        return False
    removed = 0
    if isinstance(data.get("projects"), dict):
        removed = len(data["projects"])
        del data["projects"]
    for k, v in CODEX_CONFIG_OVERRIDES.items():
        data[k] = v
    dst.write_text(_toml_emit(data) + "\n")
    print(f"  Copied config.toml (dropped {removed} project trust entries, forced bypass mode)")
    return True


def copy_claude(src_home, dst_home, name):
    src = src_home / ".claude"
    dst = dst_home / ".claude"
    if not src.exists():
        print(f"  No {src}; nothing to copy")
        return
    # The directory was created by `iso create` (it holds CLAUDE.md). We
    # write into it without touching its ownership, and explicitly skip
    # CLAUDE.md (root-locked sandbox policy).
    dst.mkdir(exist_ok=True)

    # 1. settings.json — verbatim, warn on hooks (admin paths likely won't resolve in the sandbox).
    s = src / "settings.json"
    if s.exists():
        try:
            data = json.loads(s.read_text())
            if "hooks" in data:
                print(f"  WARN: settings.json contains 'hooks' — admin commands/paths may not resolve in the sandbox; review {dst / 'settings.json'} after copy")
        except json.JSONDecodeError:
            pass
        d = dst / "settings.json"
        _replace_path(s, d)
        _own_and_perm(d, name)
        print(f"  Copied settings.json")

    # 2. agents/ and commands/ — verbatim snapshots
    for sub in ("agents", "commands"):
        s = src / sub
        if s.is_dir():
            d = dst / sub
            _replace_path(s, d)
            _own_and_perm(d, name)
            print(f"  Copied {sub}/")

    # 3. keybindings.json
    s = src / "keybindings.json"
    if s.exists():
        d = dst / "keybindings.json"
        _replace_path(s, d)
        _own_and_perm(d, name)
        print(f"  Copied keybindings.json")

    # 4. ~/.claude.json — selective: just mcpServers + pre-trust sandbox home.
    src_json = src_home / ".claude.json"
    data = {}
    if src_json.exists():
        try:
            full = json.loads(src_json.read_text())
            if "mcpServers" in full:
                data["mcpServers"] = full["mcpServers"]
                print(f"  Copying mcpServers: {list(full['mcpServers'].keys())}")
        except json.JSONDecodeError:
            pass
    data["projects"] = {
        str(dst_home): {
            "allowedTools": [],
            "hasTrustDialogAccepted": True,
        }
    }
    dst_json = dst_home / ".claude.json"
    dst_json.write_text(json.dumps(data, indent=2) + "\n")
    _own_and_perm(dst_json, name)
    print(f"  Wrote .claude.json (mcpServers + sandbox-home pre-trust)")

    # 5. plugins/ and skills/ — left empty by design.
    for sub in ("plugins", "skills"):
        _empty_dir(dst / sub, name)
        print(f"  Reset empty {sub}/")


def copy_codex(src_home, dst_home, name):
    src = src_home / ".codex"
    dst = dst_home / ".codex"
    if not src.exists():
        print(f"  No {src}; nothing to copy")
        return
    new_dir = not dst.exists()
    dst.mkdir(exist_ok=True)

    # 1. config.toml — sanitize: drop projects, force bypass-mode keys.
    s = src / "config.toml"
    if s.exists():
        d = dst / "config.toml"
        sanitize_codex_config(s, d)
        _own_and_perm(d, name)

    # 2. AGENTS.md — verbatim
    s = src / "AGENTS.md"
    if s.exists():
        d = dst / "AGENTS.md"
        _replace_path(s, d)
        _own_and_perm(d, name)
        print(f"  Copied AGENTS.md")

    # 3. agents/ — verbatim snapshot
    s = src / "agents"
    if s.is_dir():
        d = dst / "agents"
        _replace_path(s, d)
        _own_and_perm(d, name)
        print(f"  Copied agents/")

    # 4. plugins/ and skills/ — left empty by design.
    for sub in ("plugins", "skills"):
        _empty_dir(dst / sub, name)
        print(f"  Reset empty {sub}/")

    # If we just created .codex, fix its top-level perms too.
    if new_dir:
        run(["chown", f"{name}:{ISOLATOR_GROUP}", str(dst)])
        dst.chmod(0o700)


def cmd_copy(target, name, from_user):
    if target not in ("claude", "codex"):
        print(f"Unknown copy target {target!r} — must be 'claude' or 'codex'")
        sys.exit(1)
    name = validate_username(name)
    from_user = validate_username(from_user)
    if not user_exists(name):
        print(f"User {name!r} doesn't exist; create it first with `iso create {name}`")
        sys.exit(1)
    if not user_exists(from_user):
        print(f"Source user {from_user!r} doesn't exist")
        sys.exit(1)
    src_home = Path(f"/Users/{from_user}")
    dst_home = Path(f"/Users/{name}")
    if not src_home.exists() or not dst_home.exists():
        print(f"Home directory missing: src={src_home} dst={dst_home}")
        sys.exit(1)
    print(f"Copying {target} config from {from_user} -> {name}")
    if target == "claude":
        copy_claude(src_home, dst_home, name)
    else:
        copy_codex(src_home, dst_home, name)


# ── List command ────────────────────────────────────────────────────────────

def cmd_list(config):
    users = config.get("users", {})
    if not users:
        print("No users configured")
        return
    for name, uc in users.items():
        uid = uc.get("uid", "?")
        exists = "exists" if user_exists(name) else "not created"
        hosts = ", ".join(uc.get("hosts", []))
        print(f"  {name:15s} uid={uid:4}  {exists:12s}  hosts: {hosts or '(none)'}")


# ── Main ────────────────────────────────────────────────────────────────────

SUBCOMMANDS = {"create", "delete", "install", "pf", "list", "chrome", "copy"}


def parse_create_args(args):
    """Parse options for create subcommand."""
    from_user = None
    refresh_files = False
    names = []

    while args:
        arg = args.pop(0)
        if arg == "--from":
            from_user = args.pop(0)
        elif arg == "--all":
            names.append("--all")
        elif arg == "--refresh-files":
            refresh_files = True
        else:
            names.append(arg)

    return names, from_user, refresh_files


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    # Handle -s flag (SSH mode)
    use_ssh = False
    argv = sys.argv[1:]
    if argv and argv[0] == "-s":
        use_ssh = True
        argv = argv[1:]

    if not argv:
        print(__doc__)
        sys.exit(0)

    subcmd = argv[0]

    # ── iso [-s] <user> [--preserve-env=VAR1,...] [command] [args...] ──
    if subcmd not in SUBCOMMANDS and not subcmd.startswith("-"):
        subcmd = validate_username(subcmd)
        # Pull --preserve-env=... out of the argv before treating the rest
        # as the user's command. Allowed only between user and command, not
        # after — keeps positional args intact.
        rest = argv[1:]
        preserve_env = []
        while rest and rest[0].startswith("--preserve-env="):
            preserve_env += [v for v in rest[0].split("=", 1)[1].split(",") if v]
            rest = rest[1:]
        cmd = rest[0] if rest else "bash"
        cmd_args = rest[1:]
        if cmd == "remote":
            cmd_remote(subcmd, cmd_args)
            return
        if cmd == "acm":
            # Defer to the iso-acm wrapper, which runs admin-side
            # acm-shell (kube-context selection, cluster pick) and then
            # exec's into the sandbox via iso-acm-launcher. We just tell
            # the launcher which iso user to land in.
            iso_acm = Path(__file__).resolve().parent / "iso-acm"
            env = os.environ.copy()
            env["ACM_SANDBOX_USER"] = subcmd
            os.execve(str(iso_acm), [str(iso_acm)] + cmd_args, env)
        cmd_run(subcmd, cmd, cmd_args, use_ssh=use_ssh, preserve_env=preserve_env)
        return

    # Everything below requires root (except list and chrome)
    if subcmd not in ("list", "chrome") and os.geteuid() != 0:
        # Re-exec with sudo
        os.execvp("sudo", ["sudo"] + sys.argv)

    config = load_config()

    if subcmd == "create":
        names, from_user, refresh_files = parse_create_args(argv[1:])
        if not names:
            print("Usage: iso create <name> [options]")
            sys.exit(1)
        if "--all" in names:
            for name in config.get("users", {}):
                cmd_create(name, config, from_user, refresh_files=refresh_files)
        else:
            for name in names:
                cmd_create(name, config, from_user, refresh_files=refresh_files)

    elif subcmd == "delete":
        if len(argv) < 2:
            print("Usage: iso delete <name>")
            sys.exit(1)
        if argv[1] == "--all":
            for name in config.get("users", {}):
                cmd_delete(name)
        else:
            cmd_delete(argv[1])

    elif subcmd == "install":
        dry_run = "--dry-run" in argv
        cmd_install(dry_run=dry_run)

    elif subcmd == "pf":
        dry_run = "--dry-run" in argv
        cmd_pf(config, dry_run)

    elif subcmd == "chrome":
        cmd_chrome(argv[1:])

    elif subcmd == "copy":
        if len(argv) < 3:
            print("Usage: iso copy <claude|codex> <user> [--from <src-user>]")
            sys.exit(1)
        target = argv[1]
        name = argv[2]
        from_user = None
        rest = argv[3:]
        while rest:
            if rest[0] == "--from" and len(rest) > 1:
                from_user = rest[1]
                rest = rest[2:]
            else:
                print(f"Unknown arg: {rest[0]!r}")
                sys.exit(1)
        if from_user is None:
            from_user = os.environ.get("SUDO_USER") or get_admin()
        cmd_copy(target, name, from_user)

    elif subcmd == "list":
        cmd_list(config)


if __name__ == "__main__":
    main()
